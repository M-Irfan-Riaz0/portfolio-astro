---
import { WHATSAPP_URL } from '../config';

const isHome = Astro.url.pathname === '/';
const a = (anchor: string) => (isHome ? `#${anchor}` : `/#${anchor}`);

const NAV_LINKS: { label: string; anchor?: string; href?: string }[] = [
  { label: 'Solutions',   anchor: 'solutions'      },
  { label: 'Results',     anchor: 'results'        },
  { label: 'Process',     anchor: 'process'        },
  { label: 'Pricing',     anchor: 'pricing'        },
  { label: 'Marketplace', href: '/marketplace'     },
  { label: 'Blog',        href: '/blog'            },
  { label: 'FAQ',         anchor: 'faq'            },
];

const getLinkHref = (link: { anchor?: string; href?: string }) =>
  link.href ?? a(link.anchor!);
---

<nav class="sticky top-0 z-[70] px-3 pt-3 sm:px-4 sm:pt-4">
  <div class="glass-nav mx-auto flex max-w-[72rem] items-center justify-between rounded-[0.6rem] px-4 py-3 sm:px-6 sm:py-4">
    <a href="/" class="flex items-center gap-3 text-brand-primary">
        <span class="grid h-11 w-11 place-items-center rounded-xl bg-brand-primary text-lg font-bold text-white shadow-lg shadow-brand-primary/15">
        I
      </span>
      <span>
        <span class="block text-[1.05rem] font-bold tracking-tight text-brand-secondary">Irfan</span>
        <span class="block text-[10px] font-semibold uppercase tracking-[0.24em] text-brand-primary/70">Web Systems</span>
      </span>
    </a>

    <!-- Desktop links -->
    <div class="hidden items-center gap-6 text-[1rem] font-medium tracking-tight text-brand-primary/80 md:flex">
      {NAV_LINKS.map((link) => (
        <a href={getLinkHref(link)} class="transition-colors hover:text-accent">{link.label}</a>
      ))}
    </div>

    <div class="flex items-center gap-2 sm:gap-3">
      <!-- Desktop CTA -->
      <a
        href={WHATSAPP_URL}
        target="_blank"
        rel="noreferrer"
        class="hidden items-center gap-2 rounded-full bg-brand-primary px-5 py-2.5 text-sm font-semibold text-white shadow-lg shadow-brand-primary/20 transition-all hover:-translate-y-0.5 hover:bg-brand-secondary sm:inline-flex sm:px-6 sm:py-3"
      >
        <i class="fa-brands fa-whatsapp text-base" aria-hidden="true"></i>WhatsApp Inquiry
      </a>

      <!-- Hamburger (mobile only) -->
      <button
        id="nav-toggle"
        type="button"
        aria-label="Toggle navigation"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="grid h-10 w-10 place-items-center rounded-xl border border-border/80 bg-white/70 text-brand-primary transition-colors hover:bg-brand-primary/5 md:hidden"
      >
        <svg id="icon-open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="h-5 w-5">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
        <svg id="icon-close" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="hidden h-5 w-5">
          <line x1="18" y1="6" x2="6" y2="18" />
          <line x1="6" y1="6" x2="18" y2="18" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="glass-nav relative z-[80] mx-auto mt-2 hidden max-w-[72rem] rounded-[0.5rem] md:hidden"
  >
    <div class="flex flex-col gap-1 px-3 py-3">
      {NAV_LINKS.map((link) => (
        <a
          href={getLinkHref(link)}
          class="relative z-[81] rounded-lg px-3 py-3 text-[1rem] font-medium tracking-tight transition-colors hover:bg-brand-primary/5 hover:text-accent"
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  const setMenuState = (open) => {
    if (!toggle || !menu || !iconOpen || !iconClose) return;
    menu.classList.toggle('hidden', !open);
    iconOpen.classList.toggle('hidden', open);
    iconClose.classList.toggle('hidden', !open);
    toggle.setAttribute('aria-expanded', String(open));
  };

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    setMenuState(!isOpen);
  });

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => setMenuState(false));
  });
</script>
