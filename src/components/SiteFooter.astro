---
import { WHATSAPP_URL } from '../config';
---

<footer class="mx-auto max-w-7xl px-6 py-24">
  <div class="footer-watermark-shell section-shell relative overflow-hidden rounded-[2.25rem] p-10 text-center md:p-20">
    <div aria-hidden="true" class="pointer-events-none absolute inset-0 overflow-hidden">
      <span class="footer-watermark footer-watermark-left">اعتماد</span>
      <span class="footer-watermark footer-watermark-right">پاکستان</span>
    </div>
    <p class="section-kicker mb-4 text-xs font-bold uppercase text-brand-primary">Built with care, not templates</p>
    <h2 class="mb-6 text-4xl font-bold tracking-tight text-brand-secondary md:text-5xl">
      Ready to build a site that feels <span class="font-serif italic text-brand-primary">credible</span> the moment it loads?
    </h2>
    <p class="mx-auto mb-10 max-w-xl text-lg text-muted-foreground">
      Free 15-minute consultation for Pakistani startups. Strategy, pricing, and timeline explained in plain language.
    </p>
    <a
      href={WHATSAPP_URL}
      target="_blank"
      rel="noreferrer"
      class="inline-flex items-center gap-3 rounded-2xl bg-brand-primary px-8 py-4 text-lg font-bold text-white transition-transform hover:scale-105 sm:px-10 sm:py-5 sm:text-xl"
    >
      Start the conversation
      <span class="text-accent">→</span>
    </a>
    <div class="mt-12 flex flex-col items-center justify-between gap-6 border-t border-border pt-12 md:flex-row">
      <p class="font-serif text-sm italic text-muted-foreground">Based in Lahore. Designed for real businesses, not mockups.</p>
      <div class="flex gap-6 text-sm font-semibold">
        <a href="#" class="text-brand-secondary transition-colors hover:text-accent">LinkedIn</a>
        <a href="#" class="text-brand-secondary transition-colors hover:text-accent">Behance</a>
        <a href="#" class="text-brand-secondary transition-colors hover:text-accent">Twitter</a>
      </div>
    </div>
  </div>
</footer>
