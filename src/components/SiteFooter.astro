---
import { WHATSAPP_URL } from '../config';
---

<section class="px-6 pb-0 pt-20">
  <div class="ui-card mx-auto max-w-7xl rounded-[1.25rem] p-8 md:p-10">
    <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
      <div class="max-w-2xl">
        <p class="section-kicker mb-3 text-xs font-bold uppercase text-brand-primary">Pre-Footer CTA</p>
        <h2 class="text-3xl font-bold tracking-tight text-brand-secondary sm:text-4xl">
          Need a website that looks sharper, loads faster, and feels easier to trust?
        </h2>
        <p class="text-support mt-4 text-base leading-relaxed">
          Share your business, budget, and timeline. You’ll get a clear recommendation, practical next steps, and honest pricing.
        </p>
      </div>
      <a
        href={WHATSAPP_URL}
        target="_blank"
        rel="noreferrer"
        class="inline-flex shrink-0 items-center justify-center gap-3 rounded-lg bg-brand-primary px-6 py-3.5 text-base font-bold text-white transition-colors hover:bg-brand-secondary"
      >
        Book Free Consultation
        <span class="text-accent">→</span>
      </a>
    </div>
  </div>
</section>

<footer class="footer-watermark-shell relative mt-12 overflow-hidden bg-[#f4efe6]">
  <div aria-hidden="true" class="pointer-events-none absolute inset-0 overflow-hidden">
    <span class="footer-watermark footer-watermark-left">اعتماد</span>
    <span class="footer-watermark footer-watermark-right">پاکستان</span>
  </div>

  <div class="mx-auto max-w-7xl px-6 py-16 md:py-20">
    <div class="grid gap-10 border-b border-border pb-10 md:grid-cols-[1.2fr_0.8fr] md:items-start">
      <div>
        <p class="section-kicker mb-4 text-xs font-bold uppercase text-brand-primary">Built with care, not templates</p>
        <h2 class="max-w-2xl text-3xl font-bold tracking-tight text-brand-secondary sm:text-4xl">
          Websites and SEO systems for Pakistani businesses that want clarity, speed, and trust.
        </h2>
        <p class="text-support mt-4 max-w-xl text-base leading-relaxed">
          Based in Lahore. Built for startups, local businesses, and growth-focused teams who want a stronger digital presence without agency fluff.
        </p>
      </div>

      <div class="grid gap-6 sm:grid-cols-2">
        <div>
          <div class="text-sm font-bold uppercase tracking-[0.16em] text-brand-primary">Quick Links</div>
          <div class="mt-4 flex flex-col gap-3 text-sm font-semibold">
            <a href="/#solutions" class="text-brand-secondary transition-colors hover:text-accent">Solutions</a>
            <a href="/#pricing" class="text-brand-secondary transition-colors hover:text-accent">Pricing</a>
            <a href="/marketplace" class="text-brand-secondary transition-colors hover:text-accent">Marketplace</a>
            <a href="/blog" class="text-brand-secondary transition-colors hover:text-accent">Blog</a>
          </div>
        </div>

        <div>
          <div class="text-sm font-bold uppercase tracking-[0.16em] text-brand-primary">Connect</div>
          <div class="mt-4 flex flex-col gap-3 text-sm font-semibold">
            <a href={WHATSAPP_URL} target="_blank" rel="noreferrer" class="text-brand-secondary transition-colors hover:text-accent">WhatsApp</a>
            <a href="#" class="text-brand-secondary transition-colors hover:text-accent">LinkedIn</a>
            <a href="#" class="text-brand-secondary transition-colors hover:text-accent">Behance</a>
            <a href="#" class="text-brand-secondary transition-colors hover:text-accent">Twitter</a>
          </div>
        </div>
      </div>
    </div>

    <div class="text-soft-strong flex flex-col gap-4 pt-6 text-sm md:flex-row md:items-center md:justify-between">
      <p>Based in Lahore. Designed for real businesses, not mockups.</p>
      <p>Clear scope. PKR pricing. Fast WhatsApp communication.</p>
    </div>
  </div>
</footer>
