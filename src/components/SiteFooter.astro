---
import { WHATSAPP_URL } from '../config';
---

<section class="px-4 pb-0 pt-12 sm:px-6 sm:pt-16">
  <div class="ui-card mx-auto max-w-[72rem] rounded-[0.5rem] px-4 py-6 sm:px-6 sm:py-7 md:px-8 md:py-8">
    <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
      <div class="max-w-2xl text-center md:text-left">
        <p class="section-kicker mb-3 text-xs font-bold uppercase text-brand-primary">Pre-Footer CTA</p>
        <h2 class="text-3xl font-bold tracking-tight text-brand-secondary sm:text-[2.6rem]">
          Need a website that looks sharper, loads faster, and feels easier to trust?
        </h2>
        <p class="text-support mt-4 text-base leading-relaxed">
          Share your business, budget, and timeline. You’ll get a clear recommendation, practical next steps, and honest pricing.
        </p>
      </div>
      <a
        href={WHATSAPP_URL}
        target="_blank"
        rel="noreferrer"
        class="inline-flex shrink-0 items-center justify-center gap-3 rounded-lg bg-brand-primary px-6 py-3.5 text-[1.05rem] font-bold text-white transition-colors hover:bg-brand-secondary"
      >
        Book Free Consultation
        <i class="fa-solid fa-arrow-right text-sm" aria-hidden="true"></i>
      </a>
    </div>
  </div>
</section>

<footer class="footer-watermark-shell mt-12 border-t border-border/70">
  <div class="mx-auto max-w-[72rem] px-6 py-10 md:py-12">
    <div class="grid gap-8 border-b border-border/80 pb-8 md:grid-cols-[1.2fr_0.8fr_0.9fr]">
      <div>
        <p class="section-kicker mb-3 text-xs font-bold uppercase text-brand-primary">Irfan</p>
        <h2 class="max-w-xl text-2xl font-bold tracking-tight text-brand-secondary sm:text-3xl">
          Web development and SEO for Pakistani businesses.
        </h2>
        <p class="text-support mt-3 max-w-xl text-base leading-relaxed">
          Clear scope, practical execution, and fast communication for businesses that need a site that works.
        </p>
      </div>

      <div>
        <div class="text-sm font-bold uppercase tracking-[0.16em] text-brand-primary">Pages</div>
        <div class="mt-4 flex flex-col gap-3 text-[1rem] font-semibold">
          <a href="/#solutions" class="text-brand-secondary transition-colors hover:text-accent">Solutions</a>
          <a href="/#pricing" class="text-brand-secondary transition-colors hover:text-accent">Pricing</a>
          <a href="/marketplace" class="text-brand-secondary transition-colors hover:text-accent">Marketplace</a>
          <a href="/blog" class="text-brand-secondary transition-colors hover:text-accent">Blog</a>
        </div>
      </div>

      <div>
        <div class="text-sm font-bold uppercase tracking-[0.16em] text-brand-primary">Useful</div>
        <div class="mt-4 space-y-3">
          <p class="text-sm font-medium text-brand-secondary">Based in Lahore</p>
          <p class="text-sm font-medium text-brand-secondary">Pricing in PKR</p>
          <a
            href={WHATSAPP_URL}
            target="_blank"
            rel="noreferrer"
            class="inline-flex items-center gap-2 rounded-lg bg-brand-primary px-4 py-2.5 text-sm font-bold text-white transition-colors hover:bg-brand-secondary"
          >
            <i class="fa-brands fa-whatsapp text-base" aria-hidden="true"></i>
            WhatsApp
          </a>
        </div>
      </div>
    </div>

  </div>
</footer>
