---
import { WHATSAPP_URL } from '../config';
---

<section class="px-6 pb-0 pt-20">
  <div class="ui-card mx-auto max-w-[72rem] rounded-[0.5rem] p-7 md:p-8">
    <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
      <div class="max-w-2xl text-center md:text-left">
        <p class="section-kicker mb-3 text-xs font-bold uppercase text-brand-primary">Pre-Footer CTA</p>
        <h2 class="text-3xl font-bold tracking-tight text-brand-secondary sm:text-[2.6rem]">
          Need a website that looks sharper, loads faster, and feels easier to trust?
        </h2>
        <p class="text-support mt-4 text-base leading-relaxed">
          Share your business, budget, and timeline. You’ll get a clear recommendation, practical next steps, and honest pricing.
        </p>
      </div>
      <a
        href={WHATSAPP_URL}
        target="_blank"
        rel="noreferrer"
        class="inline-flex shrink-0 items-center justify-center gap-3 rounded-lg bg-brand-primary px-6 py-3.5 text-[1.05rem] font-bold text-white transition-colors hover:bg-brand-secondary"
      >
        Book Free Consultation
        <i class="fa-solid fa-arrow-right text-sm" aria-hidden="true"></i>
      </a>
    </div>
  </div>
</section>

<footer class="footer-watermark-shell relative mt-12 border-t border-border/70">
  <div class="mx-auto max-w-[72rem] px-6 py-12 md:py-14">
    <div class="grid gap-6 lg:grid-cols-[1.3fr_0.7fr]">
      <div class="ui-card rounded-[0.5rem] p-7 md:p-8">
        <p class="section-kicker mb-4 text-xs font-bold uppercase text-brand-primary">Built with care, not templates</p>
        <h2 class="max-w-3xl text-3xl font-bold tracking-tight text-brand-secondary sm:text-[2.6rem]">
          A Pakistani web partner for businesses that want clarity, speed, and trust.
        </h2>
        <p class="text-support mt-4 max-w-2xl text-base leading-relaxed">
          Based in Lahore. Built for founders, local businesses, and growth-focused teams who want a stronger digital presence without agency fluff.
        </p>

        <div class="mt-6 flex flex-wrap gap-3">
          <span class="soft-chip inline-flex items-center gap-2 rounded-full px-3 py-2 text-sm font-semibold text-brand-secondary">
            <i class="fa-solid fa-location-dot text-brand-primary" aria-hidden="true"></i>
            Lahore based
          </span>
          <span class="soft-chip inline-flex items-center gap-2 rounded-full px-3 py-2 text-sm font-semibold text-brand-secondary">
            <i class="fa-solid fa-sack-dollar text-brand-primary" aria-hidden="true"></i>
            PKR-first pricing
          </span>
          <span class="soft-chip inline-flex items-center gap-2 rounded-full px-3 py-2 text-sm font-semibold text-brand-secondary">
            <i class="fa-brands fa-whatsapp text-brand-primary" aria-hidden="true"></i>
            Fast WhatsApp communication
          </span>
        </div>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-1">
        <div class="ui-card rounded-[0.5rem] p-6">
          <div class="text-sm font-bold uppercase tracking-[0.16em] text-brand-primary">Quick Links</div>
          <div class="mt-5 flex flex-col gap-3 text-[1rem] font-semibold">
            <a href="/#solutions" class="inline-flex items-center justify-between gap-3 text-brand-secondary transition-colors hover:text-accent">
              <span>Solutions</span>
              <i class="fa-solid fa-arrow-right text-xs text-brand-primary" aria-hidden="true"></i>
            </a>
            <a href="/#pricing" class="inline-flex items-center justify-between gap-3 text-brand-secondary transition-colors hover:text-accent">
              <span>Pricing</span>
              <i class="fa-solid fa-arrow-right text-xs text-brand-primary" aria-hidden="true"></i>
            </a>
            <a href="/marketplace" class="inline-flex items-center justify-between gap-3 text-brand-secondary transition-colors hover:text-accent">
              <span>Marketplace</span>
              <i class="fa-solid fa-arrow-right text-xs text-brand-primary" aria-hidden="true"></i>
            </a>
            <a href="/blog" class="inline-flex items-center justify-between gap-3 text-brand-secondary transition-colors hover:text-accent">
              <span>Blog</span>
              <i class="fa-solid fa-arrow-right text-xs text-brand-primary" aria-hidden="true"></i>
            </a>
          </div>
        </div>

        <div class="ui-card rounded-[0.5rem] p-6">
          <div class="text-sm font-bold uppercase tracking-[0.16em] text-brand-primary">Connect</div>
          <div class="mt-5 flex flex-col gap-3 text-[1rem] font-semibold">
            <a href={WHATSAPP_URL} target="_blank" rel="noreferrer" class="inline-flex items-center gap-3 text-brand-secondary transition-colors hover:text-accent">
              <span class="grid h-9 w-9 place-items-center rounded-full bg-whatsapp/12 text-whatsapp">
                <i class="fa-brands fa-whatsapp" aria-hidden="true"></i>
              </span>
              <span>WhatsApp</span>
            </a>
            <a href="#" class="inline-flex items-center gap-3 text-brand-secondary transition-colors hover:text-accent">
              <span class="grid h-9 w-9 place-items-center rounded-full bg-brand-primary/8 text-brand-primary">
                <i class="fa-brands fa-linkedin-in" aria-hidden="true"></i>
              </span>
              <span>LinkedIn</span>
            </a>
            <a href="#" class="inline-flex items-center gap-3 text-brand-secondary transition-colors hover:text-accent">
              <span class="grid h-9 w-9 place-items-center rounded-full bg-brand-primary/8 text-brand-primary">
                <i class="fa-brands fa-behance" aria-hidden="true"></i>
              </span>
              <span>Behance</span>
            </a>
            <a href="#" class="inline-flex items-center gap-3 text-brand-secondary transition-colors hover:text-accent">
              <span class="grid h-9 w-9 place-items-center rounded-full bg-brand-primary/8 text-brand-primary">
                <i class="fa-brands fa-x-twitter" aria-hidden="true"></i>
              </span>
              <span>Twitter</span>
            </a>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-6 flex flex-col gap-3 border-t border-border/80 pt-5 text-[0.98rem] text-soft-strong md:flex-row md:items-center md:justify-between">
      <p>Designed for real businesses, not mockups.</p>
      <p>Clear scope. Straight pricing. Fast execution.</p>
    </div>
  </div>
</footer>
