---
import { WHATSAPP_URL } from '../config';
---

<!-- Floating WhatsApp widget -->
<div class="fixed bottom-5 right-5 z-[60] print:hidden">
  <button
    aria-label="Chat on WhatsApp"
    class="group relative grid h-14 w-14 place-items-center rounded-full bg-whatsapp text-white shadow-lg shadow-whatsapp/40 transition-transform hover:scale-105 active:scale-95"
    onclick={`window.open('${WHATSAPP_URL}', '_blank', 'noopener,noreferrer')`}
  >
    <span class="absolute inset-0 animate-ping rounded-full bg-whatsapp/40 [animation-duration:2.5s]"></span>
    <svg viewBox="0 0 24 24" class="relative h-7 w-7 fill-current" aria-hidden="true">
      <path d="M17.5 14.4c-.3-.1-1.7-.8-2-.9-.3-.1-.5-.1-.7.2-.2.3-.7.9-.9 1.1-.2.2-.3.2-.6.1-.3-.1-1.2-.4-2.3-1.4-.9-.8-1.4-1.7-1.6-2-.2-.3 0-.5.1-.6.1-.1.3-.3.4-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5 0-.1-.7-1.6-.9-2.2-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.4 0 1.4 1.1 2.8 1.2 3 .1.2 2.1 3.2 5 4.5.7.3 1.3.5 1.7.6.7.2 1.4.2 1.9.1.6-.1 1.7-.7 2-1.4.2-.7.2-1.2.2-1.4-.1-.1-.3-.2-.7-.4zM12 2C6.5 2 2 6.5 2 12c0 1.8.5 3.5 1.3 5L2 22l5.2-1.4c1.4.8 3.1 1.2 4.8 1.2 5.5 0 10-4.5 10-10S17.5 2 12 2z" />
    </svg>
  </button>
</div>
