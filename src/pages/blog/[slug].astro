---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import SiteNav from '../../components/SiteNav.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import blogImage from '../../assets/blog-seo.jpg';
import { WHATSAPP_URL } from '../../config';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Related posts: same category first, then fill with most recent others.
const allPosts = await getCollection('blog');
const others = allPosts.filter((p) => p.id !== post.id);
const sameCategory = others.filter((p) => p.data.category === post.data.category);
const fallback = others.filter((p) => p.data.category !== post.data.category);
const relatedPosts = [...sameCategory, ...fallback].slice(0, 3);

const pageTitle = `${post.data.title} ${post.data.titleAccent} ${post.data.titleTail} — Irfan`;
const ogImage = post.data.ogImage ?? blogImage.src;
---

<Layout
  title={pageTitle}
  description={post.data.excerpt}
  ogTitle={pageTitle}
  ogDescription={post.data.excerpt}
  ogImage={ogImage}
  ogType="article"
  twitterCard="summary_large_image"
>
  <div class="min-h-screen bg-background font-sans text-brand-secondary">

    <SiteNav />

    <!-- Hero -->
    <header class="border-b border-border">
      <div class="mx-auto max-w-3xl px-6 pb-16 pt-14 sm:pt-20">
        <div class="flex flex-wrap items-center gap-3">
          <span class="rounded-full bg-brand-primary/10 px-3 py-1 text-[10px] font-bold uppercase tracking-widest text-brand-primary">
            {post.data.category}
          </span>
          <span class="text-xs font-bold uppercase tracking-widest text-muted-foreground">
            {post.data.readMinutes} min read · {post.data.date}
          </span>
        </div>

        <h1 class="mt-6 text-4xl font-bold leading-[1.05] tracking-tighter text-brand-secondary sm:text-5xl md:text-6xl">
          {post.data.title}{" "}
          <span class="font-serif font-normal italic text-brand-primary">{post.data.titleAccent}</span>{" "}
          {post.data.titleTail}
        </h1>

        <p class="mt-6 text-lg leading-relaxed text-muted-foreground sm:text-xl">
          {post.data.excerpt}
        </p>

        <div class="mt-8 flex items-center gap-3">
          <div class="grid h-10 w-10 place-items-center rounded-full bg-brand-primary text-xs font-bold text-white">
            I
          </div>
          <div>
            <div class="text-sm font-semibold text-brand-secondary">Irfan</div>
            <div class="text-[10px] uppercase tracking-wider text-muted-foreground">Web Development & SEO</div>
          </div>
        </div>
      </div>
    </header>

    <!-- Cover image -->
    <div class="mx-auto max-w-5xl px-6 pt-10">
      <img
        src={blogImage.src}
        alt={`${post.data.titleAccent} cover`}
        width={1280}
        height={900}
        class="aspect-[16/9] w-full rounded-2xl object-cover"
      />
    </div>

    <!-- Article body — rendered from MDX -->
    <article class="mx-auto max-w-3xl space-y-10 px-6 py-16">
      <Content />

      <!-- End CTA -->
      <div class="!mt-16 rounded-2xl bg-brand-primary p-8 text-white md:p-10">
        <h2 class="text-2xl font-bold leading-tight tracking-tight sm:text-3xl">
          Apne business ke liye yeh{" "}
          <span class="font-serif italic text-accent">playbook</span> implement karwana hai?
        </h2>
        <p class="mt-3 max-w-xl text-sm leading-relaxed text-white/80">
          Free 15-min WhatsApp consultation — PKR pricing, clear timeline, koi pressure nahi.
        </p>
        <div class="mt-6 flex flex-wrap items-center gap-4">
          <a
            href={WHATSAPP_URL}
            target="_blank"
            rel="noreferrer"
            class="inline-flex items-center gap-2 rounded-xl bg-whatsapp px-5 py-3 text-sm font-bold text-white transition-all hover:brightness-110"
          >
            WhatsApp Karein →
          </a>
          <a href="/#pricing" class="text-sm font-semibold text-white/70 transition-colors hover:text-white">
            View pricing →
          </a>
        </div>
      </div>

      <!-- Back link -->
      <div class="!mt-12 text-center">
        <a
          href="/blog"
          class="inline-flex items-center gap-2 text-sm font-bold text-brand-primary transition-colors hover:text-accent"
        >
          ← Back to all posts
        </a>
      </div>
    </article>

    <!-- Related posts -->
    {relatedPosts.length > 0 && (
      <section class="border-t border-border bg-muted/30">
        <div class="mx-auto max-w-5xl px-6 py-16">
          <div class="mb-8 flex items-end justify-between gap-4">
            <div>
              <span class="text-xs font-bold uppercase tracking-[0.2em] text-brand-primary">Keep reading</span>
              <h2 class="mt-2 text-2xl font-bold tracking-tight text-brand-secondary sm:text-3xl">
                Related <span class="font-serif italic text-brand-primary">articles</span>
              </h2>
            </div>
            <a href="/blog" class="hidden shrink-0 text-sm font-bold text-brand-primary transition-colors hover:text-accent sm:inline">
              View all →
            </a>
          </div>

          <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {relatedPosts.map((rel) => (
              <a
                href={`/blog/${rel.id}`}
                class="group flex flex-col rounded-2xl border border-border bg-card p-6 transition-all hover:border-brand-primary/30 hover:shadow-lg hover:shadow-brand-primary/5"
              >
                <div class="mb-3 flex flex-wrap items-center gap-2 text-[10px] font-bold uppercase tracking-widest text-muted-foreground">
                  <span class="rounded-full bg-brand-primary/10 px-2.5 py-1 text-brand-primary">{rel.data.category}</span>
                  <span>{rel.data.readMinutes} min read</span>
                </div>
                <h3 class="mb-2 text-lg font-bold leading-tight tracking-tight text-brand-secondary">
                  {rel.data.title}{" "}
                  <span class="font-serif font-normal italic text-brand-primary">{rel.data.titleAccent}</span>{" "}
                  {rel.data.titleTail}
                </h3>
                <p class="mb-4 line-clamp-2 flex-1 text-sm leading-relaxed text-muted-foreground">
                  {rel.data.excerpt}
                </p>
                <span class="inline-flex items-center gap-1.5 text-sm font-bold text-brand-primary transition-transform group-hover:gap-2.5">
                  Read article →
                </span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <SiteFooter />

  </div>
</Layout>
