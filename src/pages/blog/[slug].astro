---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import SiteNav from '../../components/SiteNav.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import blogImage from '../../assets/blog-seo.jpg';
import { WHATSAPP_URL } from '../../config';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const pageTitle = `${post.data.title} ${post.data.titleAccent} ${post.data.titleTail} — Irfan`;
const ogImage = post.data.ogImage ?? blogImage.src;
---

<Layout
  title={pageTitle}
  description={post.data.excerpt}
  ogTitle={pageTitle}
  ogDescription={post.data.excerpt}
  ogImage={ogImage}
  ogType="article"
  twitterCard="summary_large_image"
>
  <div class="min-h-screen bg-background font-sans text-brand-secondary">

    <SiteNav />

    <!-- Hero -->
    <header class="relative overflow-hidden border-b border-border">
      <div class="pointer-events-none absolute -left-32 top-10 h-96 w-96 rounded-full bg-brand-primary/10 blur-3xl"></div>
      <div class="pointer-events-none absolute -right-20 bottom-0 h-80 w-80 rounded-full bg-accent/15 blur-3xl"></div>
      <div
        aria-hidden="true"
        class="pointer-events-none absolute -top-4 right-4 select-none text-[120px] leading-none text-brand-primary/[0.06] sm:text-[200px] md:text-[240px]"
        style="font-family: var(--font-urdu)"
        dir="rtl"
        lang="ur"
      >
        بلاگ
      </div>

      <div class="relative mx-auto max-w-3xl px-6 pb-16 pt-14 sm:pt-20">
        <div class="flex flex-wrap items-center gap-3">
          <span class="rounded-full bg-brand-primary/10 px-3 py-1 text-[10px] font-bold uppercase tracking-widest text-brand-primary">
            {post.data.category}
          </span>
          <span class="text-xs font-bold uppercase tracking-widest text-muted-foreground">
            {post.data.readMinutes} min read · {post.data.date}
          </span>
        </div>

        <h1 class="mt-6 text-4xl font-bold leading-[1.05] tracking-tighter text-brand-secondary sm:text-5xl md:text-6xl">
          {post.data.title}{" "}
          <span class="font-serif font-normal italic text-brand-primary">{post.data.titleAccent}</span>{" "}
          {post.data.titleTail}
        </h1>

        <p class="mt-6 text-lg leading-relaxed text-muted-foreground sm:text-xl">
          {post.data.excerpt}
        </p>

        <div class="mt-8 flex items-center gap-3">
          <div class="grid h-10 w-10 place-items-center rounded-full bg-brand-primary text-xs font-bold text-white">
            I
          </div>
          <div>
            <div class="text-sm font-semibold text-brand-secondary">Irfan</div>
            <div class="text-[10px] uppercase tracking-wider text-muted-foreground">Web Development & SEO</div>
          </div>
        </div>
      </div>
    </header>

    <!-- Cover image -->
    <div class="mx-auto max-w-5xl px-6 pt-10">
      <img
        src={blogImage.src}
        alt={`${post.data.titleAccent} cover`}
        width={1280}
        height={900}
        class="aspect-[16/9] w-full rounded-3xl object-cover shadow-elegant outline outline-1 -outline-offset-1 outline-black/5"
      />
    </div>

    <!-- Article body — rendered from MDX -->
    <article class="mx-auto max-w-3xl space-y-10 px-6 py-16">
      <Content />

      <!-- End CTA -->
      <div class="!mt-16 rounded-3xl bg-brand-primary p-8 text-white shadow-elegant md:p-12">
        <div
          class="text-3xl font-bold text-accent"
          style="font-family: var(--font-urdu)"
          dir="rtl"
          lang="ur"
        >
          شروع کریں
        </div>
        <h2 class="mt-3 text-3xl font-bold leading-tight tracking-tight sm:text-4xl">
          Apne business ke liye yeh{" "}
          <span class="font-serif italic text-accent">playbook</span> implement karwana hai?
        </h2>
        <p class="mt-4 max-w-xl text-base leading-relaxed text-white/80">
          Free 15-min WhatsApp consultation par aap ka business dekh kar custom local SEO plan
          banata hoon — PKR pricing, clear timeline, koi pressure nahi.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href={WHATSAPP_URL}
            target="_blank"
            rel="noreferrer"
            class="inline-flex items-center gap-2 rounded-xl bg-whatsapp px-6 py-3.5 text-sm font-bold text-white shadow-xl shadow-whatsapp/30 transition-all hover:brightness-110 sm:text-base"
          >
            WhatsApp Karein →
          </a>
          <a
            href="/#pricing"
            class="inline-flex items-center gap-2 rounded-xl border-2 border-white/20 px-6 py-3.5 text-sm font-bold transition-all hover:bg-white/10 sm:text-base"
          >
            View pricing
          </a>
        </div>
      </div>

      <!-- Back link -->
      <div class="!mt-12 text-center">
        <a
          href="/blog"
          class="inline-flex items-center gap-2 text-sm font-bold text-brand-primary transition-colors hover:text-accent"
        >
          ← Back to all posts
        </a>
      </div>
    </article>

    <SiteFooter />

  </div>
</Layout>
