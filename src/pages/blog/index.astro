---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import SiteNav from '../../components/SiteNav.astro';
import SiteFooter from '../../components/SiteFooter.astro';

const posts = await getCollection('blog');
---

<Layout
  title="Blog — Irfan | Web Development & SEO"
  description="Ideas, playbooks and SEO tips for Pakistani businesses ready to dominate Google."
  ogTitle="Blog — Irfan | Web Development & SEO"
  ogDescription="Ideas, playbooks and SEO tips for Pakistani businesses ready to dominate Google."
>
  <div class="min-h-screen bg-background font-sans text-brand-secondary">
    <SiteNav />

    <header class="relative overflow-hidden border-b border-border py-16 sm:py-24">
      <div class="pointer-events-none absolute -left-32 top-10 h-96 w-96 rounded-full bg-brand-primary/10 blur-3xl"></div>
      <div
        aria-hidden="true"
        class="pointer-events-none absolute right-6 top-10 select-none text-[140px] leading-[1.4] text-brand-primary/[0.07] sm:text-[200px]"
        style="font-family: var(--font-urdu)"
        dir="rtl"
        lang="ur"
      >
        بلاگ
      </div>
      <div class="relative mx-auto max-w-7xl px-6">
        <div class="mb-5">
          <span class="text-xs font-bold uppercase tracking-[0.25em] text-brand-primary">From the Journal</span>
        </div>
        <h1 class="text-4xl font-bold leading-tight tracking-tight text-brand-secondary sm:text-5xl">
          Ideas, playbooks & SEO <span class="font-serif italic text-brand-primary">tips</span> for Pakistani businesses.
        </h1>
      </div>
    </header>

    <main class="mx-auto max-w-7xl px-6 py-16">
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => (
          <article class="group rounded-3xl border border-border bg-card p-8 shadow-sm transition-all hover:shadow-elegant">
            <div class="mb-4 flex flex-wrap items-center gap-2 text-[10px] font-bold uppercase tracking-widest text-muted-foreground">
              <span class="rounded-full bg-brand-primary/10 px-3 py-1 text-brand-primary">{post.data.category}</span>
              <span>•</span>
              <span>{post.data.readMinutes} min read</span>
              <span>•</span>
              <span>{post.data.date}</span>
            </div>
            <h2 class="mb-3 text-xl font-bold leading-tight tracking-tight text-brand-secondary">
              {post.data.title}{' '}
              <span class="font-serif italic text-brand-primary">{post.data.titleAccent}</span>{' '}
              {post.data.titleTail}
            </h2>
            <p class="mb-6 text-sm leading-relaxed text-muted-foreground">{post.data.excerpt}</p>
            <a
              href={`/blog/${post.id}`}
              class="inline-flex items-center gap-2 text-sm font-bold text-brand-primary transition-all hover:text-accent"
            >
              Read article →
            </a>
          </article>
        ))}
      </div>
    </main>

    <SiteFooter />
  </div>
</Layout>
