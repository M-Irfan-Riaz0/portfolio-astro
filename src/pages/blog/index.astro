---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import SiteNav from '../../components/SiteNav.astro';
import SiteFooter from '../../components/SiteFooter.astro';

const posts = await getCollection('blog');
---

<Layout
  title="Blog — Irfan | Web Development & SEO"
  description="Ideas, playbooks and SEO tips for Pakistani businesses ready to dominate Google."
  ogTitle="Blog — Irfan | Web Development & SEO"
  ogDescription="Ideas, playbooks and SEO tips for Pakistani businesses ready to dominate Google."
>
  <div class="min-h-screen bg-background font-sans text-brand-secondary">
    <SiteNav />

    <header class="border-b border-border py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-6">
        <span class="text-xs font-bold uppercase tracking-[0.2em] text-brand-primary">From the Journal</span>
        <h1 class="mt-4 text-4xl font-bold leading-tight tracking-tight text-brand-secondary sm:text-5xl">
          Ideas, playbooks & SEO <span class="font-serif italic text-brand-primary">tips</span><br />for Pakistani businesses.
        </h1>
      </div>
    </header>

    <main class="mx-auto max-w-7xl px-6 py-16">
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => (
          <article class="rounded-2xl border border-border bg-card p-7">
            <div class="mb-4 flex flex-wrap items-center gap-2 text-[10px] font-bold uppercase tracking-widest text-muted-foreground">
              <span class="rounded-full bg-brand-primary/10 px-3 py-1 text-brand-primary">{post.data.category}</span>
              <span>•</span>
              <span>{post.data.readMinutes} min read</span>
              <span>•</span>
              <span>{post.data.date}</span>
            </div>
            <h2 class="mb-3 text-xl font-bold leading-tight tracking-tight text-brand-secondary">
              {post.data.title}{' '}
              <span class="font-serif italic text-brand-primary">{post.data.titleAccent}</span>{' '}
              {post.data.titleTail}
            </h2>
            <p class="mb-6 text-sm leading-relaxed text-muted-foreground">{post.data.excerpt}</p>
            <a
              href={`/blog/${post.id}`}
              class="inline-flex items-center gap-2 text-sm font-bold text-brand-primary transition-all hover:text-accent"
            >
              Read article →
            </a>
          </article>
        ))}
      </div>
    </main>

    <SiteFooter />
  </div>
</Layout>
