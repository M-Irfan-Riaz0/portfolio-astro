---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import ProcessSteps from '../components/ProcessSteps.tsx';
import heroImage from '../assets/hero-workspace.jpg';
import blogImage from '../assets/blog-seo.jpg';
import { getCollection } from 'astro:content';
import { WHATSAPP_URL } from '../config';

const allPosts = await getCollection('blog');
const featuredPost = allPosts[0];

const RESULTS = [
  {
    client: "Raza Textiles",
    city: "Faisalabad",
    metric: "+312%",
    label: "Organic traffic in 6 months",
    tag: "E-commerce SEO",
  },
  {
    client: "Lahore Estates",
    city: "Lahore",
    metric: "#1",
    label: "Ranking for 24 local keywords",
    tag: "Local SEO + Web",
  },
  {
    client: "Bloom Studio",
    city: "Karachi",
    metric: "4.2s → 0.9s",
    label: "Page load on 4G networks",
    tag: "Performance",
  },
];

const PRICING = [
  {
    name: "Starter",
    price: "Rs. 15,000",
    unit: "one-time",
    desc: "For new businesses needing a fast, credible online presence.",
    features: ["5-page custom website", "Mobile responsive", "Basic on-page SEO", "WhatsApp integration", "2 weeks delivery"],
    popular: false,
  },
  {
    name: "Professional",
    price: "Rs. 30,000",
    unit: "one-time",
    desc: "For growing brands ready to dominate Google and convert at scale.",
    features: ["Full e-commerce / custom build", "Advanced SEO campaign", "Speed & Core Web Vitals", "1 month priority support", "Conversion-focused design"],
    popular: true,
  },
  {
    name: "Growth Retainer",
    price: "Rs. 50,000",
    unit: "per month",
    desc: "Ongoing SEO and growth partnership for serious operators.",
    features: ["Monthly SEO execution", "Content & backlink strategy", "Performance reports", "Unlimited small edits", "Dedicated WhatsApp line"],
    popular: false,
  },
];

const TESTIMONIALS = [
  {
    quote: "Irfan delivered our e-commerce store in record time. Our local sales jumped 40% in the first month alone thanks to his SEO strategy.",
    name: "Ahmed Raza",
    role: "CEO, Raza Textiles",
    initials: "AR",
  },
  {
    quote: "Finally, a developer in Pakistan who understands both the technical side and the local market. Communication on WhatsApp was instant.",
    name: "Fatima Khan",
    role: "Founder, Bloom Studio",
    initials: "FK",
  },
];

const FAQS = [
  {
    q: "Aap ki pricing PKR mein hai ya USD?",
    a: "Sab pricing PKR mein hai — koi hidden currency conversion nahi. Starter package Rs. 15,000 se shuru hota hai. Bank transfer, Easypaisa, JazzCash — sab accept hain.",
  },
  {
    q: "Website banane mein kitna time lagta hai?",
    a: "Starter sites 1–2 hafton mein, full custom e-commerce 3–4 hafton mein launch ho jati hain. Aap ko weekly preview milti hai — koi guesswork nahi.",
  },
  {
    q: "Kya SEO ki guarantee dete hain ke main #1 aaunga?",
    a: "Honest jawab: koi bhi 'guaranteed #1' wala SEO expert jhoot bolta hai. Hum aap ko realistic targets dete hain, monthly reports bhejte hain, aur 3–6 mahine mein measurable growth dikhate hain.",
  },
  {
    q: "Kya aap WordPress kar sakte hain ya sirf custom code?",
    a: "Dono. Agar aap ka budget ya team WordPress ke saath comfortable hai, hum WordPress karein ge. High-performance ya unique features chahiye to Next.js / custom build best hai.",
  },
  {
    q: "Project ke baad support milta hai?",
    a: "Har project ke saath 1 month free support included hai — bug fixes, small edits, hosting help. Uske baad Growth Retainer mein unlimited edits + SEO included hain.",
  },
  {
    q: "Kya aap Pakistan ke bahar clients ke saath bhi kaam karte hain?",
    a: "Bilkul. UAE, UK, USA aur Canada ke Pakistani-owned businesses ke saath regularly kaam karte hain. Pricing USD mein adjust kar lete hain.",
  },
];
---

<Layout
  title="Irfan — Web Development & SEO Expert in Pakistan"
  description="Premium web development and technical SEO for ambitious Pakistani businesses. All-in-one digital growth partner based in Lahore."
  ogTitle="Irfan — Web Development & SEO Expert in Pakistan"
  ogDescription="Premium web development and technical SEO for ambitious Pakistani businesses."
  ogImage={heroImage.src}
>
  <div class="min-h-screen bg-background font-sans text-brand-secondary">

    <SiteNav />

    <!-- Hero -->
    <header id="top" class="relative overflow-hidden px-6 pt-6">
      <div aria-hidden="true" class="pointer-events-none absolute inset-0 overflow-hidden">
        <span class="hero-watermark hero-watermark-top">پاکستان</span>
        <span class="hero-watermark hero-watermark-bottom">ترقی</span>
      </div>
      <div class="section-shell mx-auto grid max-w-7xl items-center gap-12 overflow-hidden rounded-[2.5rem] px-6 pb-16 pt-16 sm:px-8 lg:grid-cols-[1.15fr_0.85fr] lg:gap-16 lg:px-10 lg:pb-20">

        <div class="space-y-8">
          <div class="space-y-5">
            <div class="flex flex-wrap items-center gap-3">
              <span class="soft-chip rounded-full px-4 py-2 text-[11px] font-bold uppercase tracking-[0.22em] text-brand-primary">Apple HIG inspired</span>
              <span class="soft-chip rounded-full px-4 py-2 text-[11px] font-semibold tracking-wide text-muted-foreground">Human, warm, high-trust</span>
            </div>
            <h1 class="max-w-3xl text-5xl font-bold leading-[0.98] tracking-tight text-brand-secondary sm:text-6xl lg:text-7xl">
              A website that feels
              <span class="block text-brand-primary">expensive, calm,</span>
              and deeply local.
            </h1>
            <p class="max-w-2xl text-lg leading-relaxed text-muted-foreground sm:text-xl">
              Premium web development aur technical SEO for Pakistani businesses that want trust, clarity, and real commercial results, not just a trendy landing page.
            </p>
          </div>

          <div class="flex flex-wrap items-center gap-4">
            <a
              href={WHATSAPP_URL}
              target="_blank"
              rel="noreferrer"
              class="inline-flex items-center gap-2.5 rounded-xl bg-whatsapp px-6 py-3.5 text-sm font-bold text-white shadow-md transition-all hover:brightness-110"
            >
              <svg viewBox="0 0 24 24" class="h-4 w-4 fill-current" aria-hidden="true">
                <path d="M17.5 14.4c-.3-.1-1.7-.8-2-.9-.3-.1-.5-.1-.7.2-.2.3-.7.9-.9 1.1-.2.2-.3.2-.6.1-.3-.1-1.2-.4-2.3-1.4-.9-.8-1.4-1.7-1.6-2-.2-.3 0-.5.1-.6.1-.1.3-.3.4-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5 0-.1-.7-1.6-.9-2.2-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.4 0 1.4 1.1 2.8 1.2 3 .1.2 2.1 3.2 5 4.5.7.3 1.3.5 1.7.6.7.2 1.4.2 1.9.1.6-.1 1.7-.7 2-1.4.2-.7.2-1.2.2-1.4-.1-.1-.3-.2-.7-.4zM12 2C6.5 2 2 6.5 2 12c0 1.8.5 3.5 1.3 5L2 22l5.2-1.4c1.4.8 3.1 1.2 4.8 1.2 5.5 0 10-4.5 10-10S17.5 2 12 2z" />
              </svg>
              WhatsApp Karein
            </a>
            <a href="#results" class="rounded-full border border-border/80 px-5 py-3 text-sm font-semibold text-brand-secondary transition-colors hover:border-brand-primary hover:text-brand-primary">
              Kaam dekhein
            </a>
          </div>

          <div class="grid gap-4 sm:grid-cols-3">
            <div class="ui-card rounded-[1.5rem] p-5">
              <div class="text-2xl font-bold text-brand-secondary">40+</div>
              <div class="mt-1 text-xs uppercase tracking-[0.16em] text-muted-foreground">Brands served</div>
            </div>
            <div class="ui-card rounded-[1.5rem] p-5">
              <div class="text-2xl font-bold text-brand-secondary">140%</div>
              <div class="mt-1 text-xs uppercase tracking-[0.16em] text-muted-foreground">Avg. traffic growth</div>
            </div>
            <div class="ui-card rounded-[1.5rem] p-5">
              <div class="text-2xl font-bold text-brand-secondary">Rs. 15k</div>
              <div class="mt-1 text-xs uppercase tracking-[0.16em] text-muted-foreground">Starting from</div>
            </div>
          </div>
        </div>

        <div class="space-y-5">
          <div class="relative overflow-hidden rounded-[2rem]">
            <img
              src={heroImage.src}
              alt="Modern workspace with laptop showing a website design"
              width={1024}
              height={1280}
              class="aspect-[4/5] w-full object-cover"
            />
            <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-brand-secondary/75 via-brand-secondary/20 to-transparent p-6 text-white">
              <p class="text-[11px] font-bold uppercase tracking-[0.22em] text-white/75">From Lahore, with rigor</p>
              <p class="mt-2 max-w-sm text-sm leading-relaxed text-white/88">
                Fast on 4G, clear in PKR, and designed to feel trustworthy for real customers in Pakistan.
              </p>
            </div>
          </div>

          <div class="human-note rounded-[1.75rem] p-6">
            <p class="text-[11px] font-bold uppercase tracking-[0.2em] text-brand-primary">What changes now</p>
            <p class="mt-3 text-base leading-relaxed text-brand-secondary">
              We’re moving away from “AI website vibes” and toward a more human system: softer hierarchy, deliberate spacing, clearer trust cues, and a warmer emotional tone.
            </p>
          </div>
        </div>
      </div>
    </header>

    <!-- Services -->
    <section id="solutions" class="bg-[#f7f3ea] px-6 py-20">
      <div class="mx-auto max-w-7xl px-6">
        <div class="mb-12">
          <span class="section-kicker text-xs font-bold uppercase text-brand-primary">Solutions</span>
          <h2 class="mt-2 text-3xl font-bold tracking-tight text-brand-secondary sm:text-4xl">A clearer, more premium system for growth.</h2>
          <p class="mt-3 max-w-2xl text-base leading-relaxed text-muted-foreground">
            Inspired by Apple’s calm, layered interface language, but adapted for Pakistani buying behavior: less noise, more reassurance, and stronger first-impression trust.
          </p>
        </div>
        <div class="grid gap-6 md:grid-cols-3">

          <div class="ui-card rounded-[1.75rem] p-5">
            <div class="media-panel mb-5">
              <img src={heroImage.src} alt="Custom website design preview" />
              <div class="media-overlay">
                <span class="media-label">Custom Build</span>
                <p class="mt-3 max-w-[15rem] text-sm leading-relaxed text-white/85">Structured layouts, clean mobile hierarchy, and a sharper first impression.</p>
              </div>
            </div>
            <h3 class="mb-3 text-lg font-bold text-brand-secondary">Custom Web Development</h3>
            <p class="mb-5 text-sm leading-relaxed text-muted-foreground">High-performance builds engineered for speed, trust, and a polished first impression on every screen.</p>
            <ul class="space-y-1.5 text-sm text-brand-secondary/80">
              <li>• E-commerce integration</li>
              <li>• Optimized for 4G and low-latency users</li>
              <li>• Thoughtful admin and content flows</li>
            </ul>
          </div>

          <div class="ui-card-strong rounded-[1.75rem] p-5 text-white">
            <div class="media-panel mb-5 min-h-[13rem]">
              <img src={blogImage.src} alt="SEO content and ranking strategy visual" />
              <div class="media-overlay">
                <span class="media-label">Search Growth</span>
                <p class="mt-3 max-w-[15rem] text-sm leading-relaxed text-white/85">Pages that rank, reassure, and convert instead of just chasing clicks.</p>
              </div>
            </div>
            <h3 class="mb-3 text-lg font-bold">Elite SEO Strategy</h3>
            <p class="mb-5 text-sm leading-relaxed text-white/72">We don’t just rank. We shape pages and search presence so your business feels credible before the first message arrives.</p>
            <ul class="space-y-1.5 text-sm text-white/82">
              <li>• Competitor analysis by city and niche</li>
              <li>• Content strategy with local intent</li>
              <li>• On-page structure that supports conversion</li>
            </ul>
          </div>

          <div class="ui-card rounded-[1.75rem] p-5">
            <div class="media-panel mb-5">
              <img src={heroImage.src} alt="Ongoing support and optimization workspace" class="object-[center_70%]" />
              <div class="media-overlay">
                <span class="media-label">Long-term Care</span>
                <p class="mt-3 max-w-[15rem] text-sm leading-relaxed text-white/85">A site that stays maintained, measured, and commercially sharp after launch.</p>
              </div>
            </div>
            <h3 class="mb-3 text-lg font-bold text-brand-secondary">Managed Growth</h3>
            <p class="mb-5 text-sm leading-relaxed text-muted-foreground">Continuous support so your site stays fast, secure, and emotionally reassuring after launch too.</p>
            <ul class="space-y-1.5 text-sm text-brand-secondary/80">
              <li>• Security and updates</li>
              <li>• Monthly performance reporting</li>
              <li>• Conversion-focused iteration</li>
            </ul>
          </div>

        </div>
      </div>
    </section>

    <!-- Results -->
    <section id="results" class="bg-white py-20">
      <div class="mx-auto max-w-7xl px-6">
        <div class="mb-12">
          <span class="section-kicker text-xs font-bold uppercase text-brand-primary">Our Results</span>
          <h2 class="mt-2 text-3xl font-bold text-brand-secondary sm:text-4xl">
            Real businesses. Real <span class="font-serif italic text-brand-primary">growth</span>.
          </h2>
        </div>
        <div class="grid gap-6 md:grid-cols-3">
          {RESULTS.map((c) => (
            <div class="ui-card rounded-[1.75rem] p-8">
              <div class="mb-6 flex items-center justify-between gap-3">
                <div class="text-xs font-bold uppercase tracking-widest text-muted-foreground">{c.tag}</div>
                <span class="soft-chip rounded-full px-3 py-1 text-[10px] font-bold uppercase tracking-[0.18em] text-brand-primary">Case note</span>
              </div>
              <div class="mb-2 text-5xl font-bold tracking-tighter text-brand-primary">{c.metric}</div>
              <p class="mb-6 text-sm text-muted-foreground">{c.label}</p>
              <div class="border-t border-border pt-4">
                <div class="font-semibold text-brand-secondary">{c.client}</div>
                <div class="text-xs uppercase tracking-wider text-muted-foreground">{c.city}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Process -->
    <section id="process" class="bg-[#f6f1e7] py-20">
      <div class="mx-auto max-w-7xl px-6">
        <div class="mb-12">
          <span class="section-kicker text-xs font-bold uppercase text-brand-primary">The Process</span>
          <h2 class="mt-2 text-3xl font-bold text-brand-secondary sm:text-4xl">
            Simple, transparent, on-time.
          </h2>
          <p class="mt-3 max-w-xl text-base text-muted-foreground">
            Char asaan steps — har step par aap ko poori update milti hai. Koi confusion, koi hidden charges nahi.
          </p>
        </div>
        <ProcessSteps client:load />
      </div>
    </section>

    <!-- Pricing -->
    <section id="pricing" class="bg-white py-20">
      <div class="mx-auto max-w-7xl px-6">
        <div class="mb-12">
          <span class="section-kicker text-xs font-bold uppercase text-brand-primary">Pricing</span>
          <h2 class="mt-2 text-3xl font-bold text-brand-secondary sm:text-4xl">
            Transparent rates. <span class="font-serif italic text-brand-primary">All in PKR</span>.
          </h2>
        </div>
        <div class="grid gap-6 md:grid-cols-3">
          {PRICING.map((t) => (
            <div class={t.popular
              ? "ui-card-strong relative rounded-[1.85rem] p-8 text-white"
              : "ui-card rounded-[1.85rem] p-8"
            }>
              {t.popular && (
                <div class="absolute -top-3 right-6 rounded-full bg-accent px-3 py-1 text-[10px] font-bold uppercase tracking-widest text-accent-foreground">
                  Most Popular
                </div>
              )}
              <h3 class={`text-lg font-bold ${t.popular ? 'text-white' : 'text-brand-secondary'}`}>{t.name}</h3>
              <div class="mt-3 flex items-baseline gap-2">
                <span class="text-3xl font-bold tracking-tight">{t.price}</span>
                <span class={`text-xs ${t.popular ? 'text-white/60' : 'text-muted-foreground'}`}>/{t.unit}</span>
              </div>
              <p class={`mt-3 text-sm ${t.popular ? 'text-white/70' : 'text-muted-foreground'}`}>{t.desc}</p>
              <ul class="mt-6 space-y-2.5 text-sm">
                {t.features.map((f) => (
                  <li class={`flex gap-2 ${t.popular ? 'text-white/90' : 'text-brand-secondary'}`}>
                    <span class="text-accent shrink-0">✓</span> {f}
                  </li>
                ))}
              </ul>
              <a
                href={WHATSAPP_URL}
                target="_blank"
                rel="noreferrer"
                class={t.popular
                  ? "mt-7 block rounded-xl bg-accent py-3 text-center text-sm font-bold text-accent-foreground transition-all hover:brightness-105"
                  : "mt-7 block rounded-xl border border-brand-primary/20 py-3 text-center text-sm font-bold transition-all hover:bg-brand-primary hover:border-transparent hover:text-white"
                }
              >
                Get Started
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Testimonials -->
    <section class="bg-[#f7f3ea] py-20">
      <div class="mx-auto max-w-7xl px-6">
        <div class="mb-12">
          <span class="section-kicker text-xs font-bold uppercase text-brand-primary">Testimonials</span>
        </div>
        <div class="grid gap-6 md:grid-cols-2">
          {TESTIMONIALS.map((t) => (
            <div class="ui-card rounded-[1.85rem] p-8">
              <p class="text-xl leading-relaxed text-brand-secondary">
                "{t.quote}"
              </p>
              <div class="mt-6 flex items-center gap-3">
                <div class="grid h-10 w-10 shrink-0 place-items-center rounded-full bg-brand-primary text-xs font-bold text-white">
                  {t.initials}
                </div>
                <div>
                  <p class="font-semibold text-brand-secondary">{t.name}</p>
                  <p class="text-xs text-muted-foreground">{t.role}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Blog -->
    <section id="blog" class="bg-white py-20">
      <div class="mx-auto max-w-7xl px-6">
        <div class="mb-12 flex items-end justify-between">
          <div>
            <span class="section-kicker text-xs font-bold uppercase text-brand-primary">From the Journal</span>
            <h2 class="mt-2 text-3xl font-bold text-brand-secondary sm:text-4xl">
              Ideas & SEO tips for<br />Pakistani businesses.
            </h2>
          </div>
          <a
            href="/blog"
            class="hidden rounded-full border border-border px-5 py-2.5 text-sm font-bold transition-all hover:border-brand-primary hover:text-brand-primary md:inline-flex"
          >
            View all →
          </a>
        </div>

        <article class="ui-card grid overflow-hidden rounded-[2rem] md:grid-cols-2">
          <a href={`/blog/${featuredPost.id}`} class="relative block overflow-hidden">
            <img
              src={blogImage.src}
              alt="SEO article thumbnail"
              width={1280}
              height={900}
              loading="lazy"
              class="aspect-[4/3] h-full w-full object-cover transition-transform duration-500 hover:scale-105"
            />
            <span class="absolute left-4 top-4 rounded-full bg-accent px-3 py-1 text-[10px] font-bold uppercase tracking-widest text-accent-foreground">
              Featured
            </span>
          </a>
          <div class="flex flex-col justify-between p-8">
            <div class="space-y-4">
              <div class="flex flex-wrap items-center gap-2 text-xs text-muted-foreground">
                <span class="soft-chip rounded-full px-2.5 py-1 text-[10px] font-bold uppercase text-brand-primary">{featuredPost.data.category}</span>
                <span>{featuredPost.data.readMinutes} min read</span>
                <span>·</span>
                <span>{featuredPost.data.date}</span>
              </div>
              <h3 class="text-2xl font-bold leading-snug text-brand-secondary">
                {featuredPost.data.title}{" "}
                <span class="text-brand-primary">{featuredPost.data.titleAccent}</span>{" "}
                {featuredPost.data.titleTail}
              </h3>
              <p class="text-sm leading-relaxed text-muted-foreground">{featuredPost.data.excerpt}</p>
            </div>
            <div class="mt-6 flex items-center justify-between border-t border-border pt-5">
              <div class="flex items-center gap-2.5">
                <div class="grid h-9 w-9 place-items-center rounded-full bg-brand-primary text-xs font-bold text-white">I</div>
                <div>
                  <div class="text-sm font-semibold text-brand-secondary">Irfan</div>
                  <div class="text-[10px] text-muted-foreground">Web + SEO</div>
                </div>
              </div>
              <a href={`/blog/${featuredPost.id}`} class="text-sm font-bold text-brand-primary transition-colors hover:text-accent">
                Read →
              </a>
            </div>
          </div>
        </article>
      </div>
    </section>

    <!-- Trust logos -->
    <section class="bg-[#f4efe6] py-16">
      <div class="mx-auto max-w-7xl px-6">
        <p class="mb-8 text-center text-xs font-bold uppercase tracking-[0.2em] text-muted-foreground">
          Trusted by businesses in Karachi, Lahore & Islamabad
        </p>
        <div class="flex flex-wrap items-center justify-center gap-10 opacity-40 md:gap-20">
          <div class="text-xl font-black">TECH-PK</div>
          <div class="text-xl font-black">IndusGlobal</div>
          <div class="text-xl font-black tracking-widest">ZINC</div>
          <div class="text-xl font-black uppercase">Noor.Dev</div>
          <div class="text-xl font-black">Sahara&Co</div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section id="faq" class="bg-white py-20">
      <div class="mx-auto max-w-4xl px-6">
        <div class="mb-12">
          <span class="section-kicker text-xs font-bold uppercase text-brand-primary">FAQ</span>
          <h2 class="mt-2 text-3xl font-bold text-brand-secondary sm:text-4xl">
            Aap ke sawaalaat, seedhe jawab.
          </h2>
          <p class="mt-3 text-muted-foreground">
            Pricing, timeline, SEO aur post-launch support ke baare mein.
          </p>
        </div>

        <div class="space-y-3">
          {FAQS.map((f, i) => (
            <details open={i === 0} class="ui-card group rounded-[1.5rem]">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-4 p-5">
                <span class="text-base font-semibold text-brand-secondary">{f.q}</span>
                <span
                  aria-hidden="true"
                  class="grid h-7 w-7 shrink-0 place-items-center rounded-full border border-border text-sm text-brand-primary transition-transform duration-200 group-open:rotate-45"
                >
                  +
                </span>
              </summary>
              <div class="border-t border-border px-5 pb-5 pt-4 text-sm leading-relaxed text-muted-foreground">
                {f.a}
              </div>
            </details>
          ))}
        </div>

        <div class="human-note mt-8 rounded-[1.75rem] p-6 text-center">
          <p class="text-sm text-muted-foreground">Koi aur sawal hai?</p>
          <a
            href={WHATSAPP_URL}
            target="_blank"
            rel="noreferrer"
