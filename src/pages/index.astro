---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import ProcessSteps from '../components/ProcessSteps.tsx';
import heroImage from '../assets/hero-workspace.jpg';
import blogImage from '../assets/blog-seo.jpg';
import { getCollection } from 'astro:content';
import { WHATSAPP_URL } from '../config';

const allPosts = await getCollection('blog');
const featuredPost = allPosts[0];

const RESULTS = [
  {
    client: "Raza Textiles",
    city: "Faisalabad",
    metric: "+312%",
    label: "Organic traffic in 6 months",
    tag: "E-commerce SEO",
  },
  {
    client: "Lahore Estates",
    city: "Lahore",
    metric: "#1",
    label: "Ranking for 24 local keywords",
    tag: "Local SEO + Web",
  },
  {
    client: "Bloom Studio",
    city: "Karachi",
    metric: "4.2s → 0.9s",
    label: "Page load on 4G networks",
    tag: "Performance",
  },
];

const PRICING = [
  {
    name: "Starter",
    price: "Rs. 15,000",
    unit: "one-time",
    desc: "For new businesses needing a fast, credible online presence.",
    features: ["5-page custom website", "Mobile responsive", "Basic on-page SEO", "WhatsApp integration", "2 weeks delivery"],
    popular: false,
  },
  {
    name: "Professional",
    price: "Rs. 30,000",
    unit: "one-time",
    desc: "For growing brands ready to dominate Google and convert at scale.",
    features: ["Full e-commerce / custom build", "Advanced SEO campaign", "Speed & Core Web Vitals", "1 month priority support", "Conversion-focused design"],
    popular: true,
  },
  {
    name: "Growth Retainer",
    price: "Rs. 50,000",
    unit: "per month",
    desc: "Ongoing SEO and growth partnership for serious operators.",
    features: ["Monthly SEO execution", "Content & backlink strategy", "Performance reports", "Unlimited small edits", "Dedicated WhatsApp line"],
    popular: false,
  },
];

const TESTIMONIALS = [
  {
    quote: "Irfan delivered our e-commerce store in record time. Our local sales jumped 40% in the first month alone thanks to his SEO strategy.",
    name: "Ahmed Raza",
    role: "CEO, Raza Textiles",
    initials: "AR",
  },
  {
    quote: "Finally, a developer in Pakistan who understands both the technical side and the local market. Communication on WhatsApp was instant.",
    name: "Fatima Khan",
    role: "Founder, Bloom Studio",
    initials: "FK",
  },
];

const FAQS = [
  {
    q: "Aap ki pricing PKR mein hai ya USD?",
    qEn: "Is pricing in PKR or USD?",
    a: "Sab pricing PKR mein hai — koi hidden currency conversion nahi. Starter package Rs. 15,000 se shuru hota hai. Bank transfer, Easypaisa, JazzCash — sab accept hain.",
  },
  {
    q: "Website banane mein kitna time lagta hai?",
    qEn: "How long does a website take?",
    a: "Starter sites 1–2 hafton mein, full custom e-commerce 3–4 hafton mein launch ho jati hain. Aap ko weekly preview milti hai — koi guesswork nahi.",
  },
  {
    q: "Kya SEO ki guarantee dete hain ke main #1 aaunga?",
    qEn: "Do you guarantee #1 Google rankings?",
    a: "Honest jawab: koi bhi 'guaranteed #1' wala SEO expert jhoot bolta hai. Hum aap ko realistic targets dete hain, monthly reports bhejte hain, aur 3–6 mahine mein measurable growth dikhate hain.",
  },
  {
    q: "Kya aap WordPress kar sakte hain ya sirf custom code?",
    qEn: "WordPress or custom code?",
    a: "Dono. Agar aap ka budget ya team WordPress ke saath comfortable hai, hum WordPress karein ge. High-performance ya unique features chahiye to Next.js / custom build best hai. Aap ki zaroorat dekh kar suggest karte hain.",
  },
  {
    q: "Project ke baad support milta hai?",
    qEn: "What about post-launch support?",
    a: "Har project ke saath 1 month free support included hai — bug fixes, small edits, hosting help. Uske baad Growth Retainer (Rs. 50,000/month) mein unlimited edits + SEO included hain.",
  },
  {
    q: "Kya aap Pakistan ke bahar clients ke saath bhi kaam karte hain?",
    qEn: "Do you work with international clients?",
    a: "Bilkul. UAE, UK, USA aur Canada ke Pakistani-owned businesses ke saath regularly kaam karte hain. Pricing USD mein adjust kar lete hain aur timezone-friendly meetings rakhte hain.",
  },
];
---

<Layout
  title="Irfan — Web Development & SEO Expert in Pakistan"
  description="Premium web development and technical SEO for ambitious Pakistani businesses. All-in-one digital growth partner based in Lahore."
  ogTitle="Irfan — Web Development & SEO Expert in Pakistan"
  ogDescription="Premium web development and technical SEO for ambitious Pakistani businesses. All-in-one digital growth partner based in Lahore."
  ogImage={heroImage.src}
>
  <div class="min-h-screen bg-background font-sans text-brand-secondary selection:bg-accent/30">

    <SiteNav />

    <!-- Hero -->
    <header id="top" class="relative overflow-hidden border-b border-border">
      <div class="pointer-events-none absolute -left-32 top-20 h-96 w-96 rounded-full bg-brand-primary/10 blur-3xl"></div>
      <div class="pointer-events-none absolute -right-20 bottom-0 h-80 w-80 rounded-full bg-accent/20 blur-3xl"></div>
      <div
        aria-hidden="true"
        class="pointer-events-none absolute right-6 top-24 select-none text-[140px] leading-[1.4] text-brand-primary/[0.07] sm:text-[220px] md:top-28 md:text-[280px]"
        style="font-family: var(--font-urdu)"
        dir="rtl"
        lang="ur"
      >
        ترقی
      </div>

      <div class="relative mx-auto grid max-w-7xl items-center gap-14 px-6 pb-28 pt-16 lg:grid-cols-[1.1fr_1fr] lg:gap-16 lg:pt-20">
        <div class="space-y-7">
          <div class="flex items-center gap-3">
            <span class="h-1 w-6 rounded-full bg-brand-primary"></span>
            <span class="text-xs font-bold uppercase tracking-[0.25em] text-brand-primary">
              Assalam-o-Alaikum
            </span>
          </div>

          <h1 class="text-[2.75rem] font-bold leading-[0.95] tracking-tighter text-brand-secondary sm:text-6xl md:text-7xl">
            Aap ka business,{" "}
            <span class="relative inline-block">
              <span class="font-serif font-normal italic text-brand-primary">Google</span>
              <svg
                aria-hidden="true"
                viewBox="0 0 200 12"
                class="absolute -bottom-2 left-0 h-2 w-full text-accent"
                preserveAspectRatio="none"
              >
                <path d="M2 8 Q 50 1 100 6 T 198 5" stroke="currentColor" stroke-width="3" fill="none" stroke-linecap="round" />
              </svg>
            </span>{" "}
            ke top par.
          </h1>

          <p class="max-w-xl text-lg leading-relaxed text-muted-foreground sm:text-xl">
            Premium web development aur technical SEO — Pakistani businesses ke liye, jo apni
            market mein <span class="font-semibold text-brand-secondary">no. 1</span> banna chahte hain.
            Lahore se, dunya tak.
          </p>

          <div class="flex flex-wrap items-center gap-4 pt-2">
            <a
              href={WHATSAPP_URL}
              target="_blank"
              rel="noreferrer"
              class="group inline-flex items-center gap-3 rounded-xl bg-whatsapp px-6 py-4 text-base font-bold text-white shadow-xl shadow-whatsapp/30 transition-all hover:brightness-110 sm:text-lg"
            >
              <svg viewBox="0 0 24 24" class="h-5 w-5 fill-current" aria-hidden="true">
                <path d="M17.5 14.4c-.3-.1-1.7-.8-2-.9-.3-.1-.5-.1-.7.2-.2.3-.7.9-.9 1.1-.2.2-.3.2-.6.1-.3-.1-1.2-.4-2.3-1.4-.9-.8-1.4-1.7-1.6-2-.2-.3 0-.5.1-.6.1-.1.3-.3.4-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5 0-.1-.7-1.6-.9-2.2-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.4 0 1.4 1.1 2.8 1.2 3 .1.2 2.1 3.2 5 4.5.7.3 1.3.5 1.7.6.7.2 1.4.2 1.9.1.6-.1 1.7-.7 2-1.4.2-.7.2-1.2.2-1.4-.1-.1-.3-.2-.7-.4zM12 2C6.5 2 2 6.5 2 12c0 1.8.5 3.5 1.3 5L2 22l5.2-1.4c1.4.8 3.1 1.2 4.8 1.2 5.5 0 10-4.5 10-10S17.5 2 12 2z" />
              </svg>
              WhatsApp Karein
            </a>
            <a
              href="#results"
              class="inline-flex items-center gap-2 rounded-xl border-2 border-brand-primary/15 bg-card/60 px-6 py-4 text-base font-bold backdrop-blur transition-all hover:border-brand-primary hover:bg-card sm:text-lg"
            >
              Kaam Dekhein →
            </a>
          </div>

          <!-- Trust strip -->
          <div class="flex flex-wrap items-center gap-x-8 gap-y-4 pt-6">
            <div class="flex items-center gap-2">
              <span class="relative flex h-2.5 w-2.5">
                <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-whatsapp opacity-75"></span>
                <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-whatsapp"></span>
              </span>
              <span class="text-xs font-semibold text-muted-foreground">Available — replies in 2 hours</span>
            </div>
            <div class="flex -space-x-2">
              {["AR", "FK", "MZ", "SI"].map((initial) => (
                <div class="grid h-8 w-8 place-items-center rounded-full border-2 border-background bg-brand-primary text-[10px] font-bold text-white">
                  {initial}
                </div>
              ))}
            </div>
            <span class="text-xs text-muted-foreground">
              <span class="font-bold text-brand-secondary">40+</span> Pakistani brands served
            </span>
          </div>
        </div>

        <!-- Visual -->
        <div class="relative">
          <div class="relative">
            <img
              src={heroImage.src}
              alt="Modern workspace with laptop showing a website design and framed line-art map of Pakistan"
              width={1024}
              height={1280}
              class="aspect-[4/5] w-full rounded-3xl object-cover shadow-elegant outline outline-1 -outline-offset-1 outline-black/5"
            />

            <!-- Metric card top-right -->
            <div class="absolute -right-3 top-8 rounded-2xl border border-border bg-card/95 p-4 shadow-xl backdrop-blur sm:-right-6 sm:p-5">
              <div class="text-[10px] font-bold uppercase tracking-widest text-muted-foreground">
                Avg. Organic Growth
              </div>
              <div class="mt-1 flex items-baseline gap-1">
                <span class="text-3xl font-bold text-brand-primary sm:text-4xl">140%</span>
                <span class="text-xs font-semibold text-whatsapp">↑</span>
              </div>
            </div>

            <!-- PKR card bottom-left -->
            <div class="absolute -bottom-6 -left-3 rounded-2xl bg-brand-primary p-5 text-white shadow-2xl sm:-left-6 sm:p-6">
              <div class="text-[10px] uppercase tracking-widest text-white/60">Starting from</div>
              <div class="mt-1 text-2xl font-bold sm:text-3xl">Rs. 15,000</div>
              <div class="text-[10px] text-accent">All-in-one website</div>
            </div>

            <!-- Urdu seal bottom-right -->
            <div class="absolute -bottom-5 right-4 grid h-24 w-24 place-items-center rounded-full bg-accent text-center text-brand-secondary shadow-xl ring-4 ring-background sm:h-28 sm:w-28">
              <div class="flex flex-col items-center gap-1 px-2">
                <div class="text-lg font-black uppercase tracking-tight">Quality</div>
                <div class="h-px w-6 bg-brand-secondary/30"></div>
                <div class="text-[9px] font-bold uppercase tracking-[0.18em]">First</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </header>

    <!-- Services -->
    <section id="solutions" class="bg-brand-primary py-24 text-white">
      <div class="mx-auto max-w-7xl px-6">
        <div class="mb-16 space-y-4">
          <h2 class="text-sm font-bold uppercase tracking-[0.3em] text-accent">Solutions</h2>
          <p class="text-3xl font-bold sm:text-4xl">The All-in-One Growth Engine</p>
        </div>
        <div class="grid gap-6 md:grid-cols-3 md:gap-8">

          <!-- Card 1 -->
          <div class="rounded-3xl border border-white/5 bg-brand-secondary/50 p-8 transition-all hover:border-accent/30">
            <div class="mb-6 flex h-12 w-12 items-center justify-center rounded-xl bg-accent/10">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 text-accent">
                <polyline points="16 18 22 12 16 6" />
                <polyline points="8 6 2 12 8 18" />
              </svg>
            </div>
            <h3 class="mb-4 text-xl font-bold">Custom Web Development</h3>
            <p class="mb-6 leading-relaxed text-white/60">High-performance Next.js and WordPress builds engineered for speed, reliability, and a world-class user experience.</p>
            <ul class="space-y-2 text-sm text-white/80">
              <li>• E-commerce Integration</li>
              <li>• Optimized for 4G/Low Latency</li>
              <li>• Custom Admin Dashboards</li>
            </ul>
          </div>

          <!-- Card 2 -->
          <div class="rounded-3xl border border-white/5 bg-brand-secondary/50 p-8 transition-all hover:border-accent/30">
            <div class="mb-6 flex h-12 w-12 items-center justify-center rounded-xl bg-accent/10">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 text-accent">
                <circle cx="11" cy="11" r="7" />
                <line x1="21" y1="21" x2="16.5" y2="16.5" />
              </svg>
            </div>
            <h3 class="mb-4 text-xl font-bold">Elite SEO Strategy</h3>
            <p class="mb-6 leading-relaxed text-white/60">We don't just rank — we convert. Targeted local SEO across Pakistani cities and global optimization for export markets.</p>
            <ul class="space-y-2 text-sm text-white/80">
              <li>• Competitor Analysis</li>
              <li>• Content Strategy</li>
              <li>• Backlink Outreach</li>
            </ul>
          </div>

          <!-- Card 3 -->
          <div class="rounded-3xl border border-white/5 bg-brand-secondary/50 p-8 transition-all hover:border-accent/30">
            <div class="mb-6 flex h-12 w-12 items-center justify-center rounded-xl bg-accent/10">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 text-accent">
                <polyline points="3 17 9 11 13 15 21 7" />
                <polyline points="15 7 21 7 21 13" />
              </svg>
            </div>
            <h3 class="mb-4 text-xl font-bold">Managed Growth</h3>
            <p class="mb-6 leading-relaxed text-white/60">Continuous support and maintenance so your site stays fast, secure, and ahead of every algorithm update.</p>
            <ul class="space-y-2 text-sm text-white/80">
              <li>• Security & Updates</li>
              <li>• Monthly Performance Reports</li>
              <li>• Conversion Rate Optimization</li>
            </ul>
          </div>

        </div>
      </div>
    </section>

    <!-- Results -->
    <section id="results" class="relative mx-auto max-w-7xl px-6 py-24">
      <div class="mb-14 max-w-2xl space-y-5">
        <span class="text-xs font-bold uppercase tracking-[0.25em] text-brand-primary">Our Results</span>
        <p class="text-3xl font-bold text-brand-secondary sm:text-4xl">
          Real businesses. Real <span class="font-serif italic text-brand-primary">growth</span>.
        </p>
      </div>

      <div class="grid gap-8 md:grid-cols-3">
        {RESULTS.map((c) => (
          <div class="group rounded-3xl border border-border bg-card p-8 transition-all hover:shadow-elegant">
            <div class="mb-8 text-xs font-bold uppercase tracking-widest text-accent">{c.tag}</div>
            <div class="mb-2 text-5xl font-bold tracking-tighter text-brand-primary">{c.metric}</div>
            <p class="mb-6 text-sm text-muted-foreground">{c.label}</p>
            <div class="border-t border-border pt-4">
              <div class="font-semibold text-brand-secondary">{c.client}</div>
              <div class="text-xs uppercase tracking-wider text-muted-foreground">{c.city}</div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Process -->
    <section id="process" class="relative overflow-hidden border-y border-border bg-muted/40 py-24">
      <div class="pointer-events-none absolute -right-40 top-10 h-96 w-96 rounded-full bg-brand-primary/10 blur-3xl"></div>
      <div class="pointer-events-none absolute -left-20 bottom-0 h-80 w-80 rounded-full bg-accent/15 blur-3xl"></div>

      <div class="relative mx-auto max-w-7xl px-6">
        <div class="mb-16 flex flex-col items-start justify-between gap-8 md:flex-row md:items-end">
          <div class="max-w-2xl space-y-5">
            <span class="text-xs font-bold uppercase tracking-[0.25em] text-brand-primary">The Process</span>
            <p class="text-4xl font-bold leading-tight tracking-tight text-brand-secondary sm:text-5xl">
              Simple, transparent,{" "}
              <span class="relative inline-block">
                <span class="font-serif italic text-brand-primary">on-time</span>
                <svg aria-hidden="true" viewBox="0 0 160 12" class="absolute -bottom-1 left-0 h-2 w-full text-accent" preserveAspectRatio="none">
                  <path d="M2 8 Q 40 1 80 6 T 158 5" stroke="currentColor" stroke-width="3" fill="none" stroke-linecap="round" />
                </svg>
              </span>.
            </p>
            <p class="text-base text-muted-foreground sm:text-lg">
              Char asaan steps — har step par aap ko poori update milti hai. Koi confusion, koi hidden charges nahi.
            </p>
          </div>
          <div class="hidden rounded-2xl border border-border bg-card px-5 py-4 shadow-sm md:block">
            <div class="text-[10px] font-bold uppercase tracking-widest text-muted-foreground">Avg. delivery</div>
            <div class="mt-1 text-2xl font-bold text-brand-primary">2–4 weeks</div>
          </div>
        </div>

        <ProcessSteps client:load />

        <!-- CTA bar -->
        <div class="mt-12 flex flex-col items-center justify-between gap-4 rounded-2xl border border-brand-primary/10 bg-brand-primary/5 px-6 py-5 sm:flex-row">
          <p class="text-center font-serif text-lg italic text-brand-secondary sm:text-left">
            "Pehle chai, phir strategy." — let's start with a quick chat.
          </p>
          <a
            href={WHATSAPP_URL}
            target="_blank"
            rel="noreferrer"
            class="inline-flex shrink-0 items-center gap-2 rounded-xl bg-whatsapp px-5 py-3 text-sm font-bold text-white shadow-lg shadow-whatsapp/25 transition-all hover:brightness-110"
          >
            Book Discovery Call →
          </a>
        </div>
      </div>
    </section>

    <!-- Pricing -->
    <section id="pricing" class="mx-auto max-w-7xl px-6 py-24">
      <div class="mb-16 max-w-2xl space-y-4">
        <h2 class="text-sm font-bold uppercase tracking-[0.3em] text-brand-primary">Pricing</h2>
        <p class="text-3xl font-bold text-brand-secondary sm:text-4xl">
          Transparent rates. <span class="font-serif italic text-brand-primary">All in PKR</span>.
        </p>
      </div>
      <div class="grid gap-6 md:grid-cols-3 md:gap-8">
        {PRICING.map((t) => (
          <div class={t.popular ? "relative rounded-3xl bg-brand-primary p-8 text-white shadow-elegant" : "rounded-3xl border border-border bg-card p-8"}>
            {t.popular && (
              <div class="absolute -top-3 right-8 rounded-full bg-accent px-3 py-1 text-[10px] font-bold uppercase tracking-widest text-accent-foreground">
                Most Popular
              </div>
            )}
            <h3 class={t.popular ? "text-lg font-semibold text-white" : "text-lg font-semibold text-brand-secondary"}>
              {t.name}
            </h3>
            <div class="mt-4 flex items-baseline gap-2">
              <span class="text-4xl font-bold tracking-tight">{t.price}</span>
              <span class={t.popular ? "text-xs text-white/60" : "text-xs text-muted-foreground"}>/{t.unit}</span>
            </div>
            <p class={t.popular ? "mt-4 text-sm text-white/70" : "mt-4 text-sm text-muted-foreground"}>{t.desc}</p>
            <ul class="mt-8 space-y-3 text-sm">
              {t.features.map((f) => (
                <li class={t.popular ? "flex gap-2 text-white/90" : "flex gap-2"}>
                  <span class="text-accent">✓</span> {f}
                </li>
              ))}
            </ul>
            <a
              href={WHATSAPP_URL}
              target="_blank"
              rel="noreferrer"
              class={t.popular
                ? "mt-8 block rounded-xl bg-accent py-3 text-center text-sm font-bold text-accent-foreground transition-all hover:brightness-105"
                : "mt-8 block rounded-xl border-2 border-brand-primary/10 py-3 text-center text-sm font-bold transition-all hover:bg-brand-primary hover:text-white"}
            >
              Get Started
            </a>
          </div>
        ))}
      </div>
    </section>

    <!-- Testimonials -->
    <section class="border-y border-border bg-brand-primary/5 py-24">
      <div class="mx-auto grid max-w-7xl gap-12 px-6 md:grid-cols-2">
        {TESTIMONIALS.map((t) => (
          <div class="space-y-6">
            <p class="font-serif text-2xl italic leading-snug text-brand-secondary sm:text-3xl">
              "{t.quote}"
            </p>
            <div class="flex items-center gap-4">
              <div class="grid h-12 w-12 place-items-center rounded-full bg-brand-primary font-bold text-white">
                {t.initials}
              </div>
              <div>
                <p class="font-semibold text-brand-secondary">{t.name}</p>
                <p class="text-xs uppercase tracking-wider text-muted-foreground">{t.role}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Blog -->
    <section id="blog" class="relative overflow-hidden border-y border-border bg-muted/40 py-24">
      <div class="pointer-events-none absolute -left-32 top-10 h-96 w-96 rounded-full bg-accent/15 blur-3xl"></div>
      <div
        aria-hidden="true"
        class="pointer-events-none absolute right-6 top-10 select-none text-[140px] leading-[1.4] text-brand-primary/[0.07] sm:text-[200px] md:text-[240px]"
        style="font-family: var(--font-urdu)"
        dir="rtl"
        lang="ur"
      >
        بلاگ
      </div>

      <div class="relative mx-auto max-w-7xl px-6">
        <div class="mb-14 flex flex-col items-start justify-between gap-6 md:flex-row md:items-end">
          <div class="max-w-2xl space-y-5">
            <span class="text-xs font-bold uppercase tracking-[0.25em] text-brand-primary">From the Journal</span>
            <p class="text-3xl font-bold leading-tight tracking-tight text-brand-secondary sm:text-4xl">
              Ideas, playbooks & SEO <span class="font-serif italic text-brand-primary">tips</span> for Pakistani businesses.
            </p>
          </div>
          <a
            href="/blog"
            class="inline-flex items-center gap-2 rounded-full border-2 border-brand-primary/10 px-5 py-3 text-sm font-bold transition-all hover:border-brand-primary hover:bg-brand-primary hover:text-white"
          >
            View all posts →
          </a>
        </div>

        <article class="grid overflow-hidden rounded-3xl border border-border bg-card shadow-sm transition-all hover:shadow-elegant md:grid-cols-2">
          <a href={`/blog/${featuredPost.id}`} class="relative block overflow-hidden">
            <img
              src={blogImage.src}
              alt="Open notebook with SEO keyword notes in English and Urdu next to a cup of karak chai"
              width={1280}
              height={900}
              loading="lazy"
              class="aspect-[4/3] h-full w-full object-cover transition-transform duration-700 hover:scale-105"
            />
            <span class="absolute left-5 top-5 rounded-full bg-accent px-3 py-1 text-[10px] font-bold uppercase tracking-widest text-accent-foreground">
              Featured
            </span>
          </a>
          <div class="flex flex-col justify-between gap-6 p-8 md:p-10">
            <div class="space-y-5">
              <div class="flex flex-wrap items-center gap-2 text-[10px] font-bold uppercase tracking-widest text-muted-foreground">
                <span class="rounded-full bg-brand-primary/10 px-3 py-1 text-brand-primary">{featuredPost.data.category}</span>
                <span>•</span>
                <span>{featuredPost.data.readMinutes} min read</span>
                <span>•</span>
                <span>{featuredPost.data.date}</span>
              </div>
              <h3 class="text-3xl font-bold leading-tight tracking-tight text-brand-secondary sm:text-4xl">
                {featuredPost.data.title}{" "}
                <span class="font-serif italic text-brand-primary">{featuredPost.data.titleAccent}</span>{" "}
                {featuredPost.data.titleTail}
              </h3>
              <p class="text-base leading-relaxed text-muted-foreground">
                {featuredPost.data.excerpt}
              </p>
              <ul class="space-y-2 text-sm text-muted-foreground">
                <li class="flex gap-2"><span class="text-accent">✓</span> Google Business Profile ko sahi tarah optimize karna</li>
                <li class="flex gap-2"><span class="text-accent">✓</span> Urdu + English keyword research strategy</li>
                <li class="flex gap-2"><span class="text-accent">✓</span> Local backlinks aur citations</li>
              </ul>
            </div>
            <div class="flex items-center justify-between border-t border-border pt-6">
              <div class="flex items-center gap-3">
                <div class="grid h-10 w-10 place-items-center rounded-full bg-brand-primary text-xs font-bold text-white">
                  I
                </div>
                <div>
                  <div class="text-sm font-semibold text-brand-secondary">Irfan</div>
                  <div class="text-[10px] uppercase tracking-wider text-muted-foreground">Web + SEO</div>
                </div>
              </div>
              <a
                href={`/blog/${featuredPost.id}`}
                class="inline-flex items-center gap-2 text-sm font-bold text-brand-primary transition-all hover:text-accent"
              >
                Read article →
              </a>
            </div>
          </div>
        </article>
      </div>
    </section>

    <!-- Trust logos -->
    <section class="py-20">
      <div class="mx-auto max-w-7xl px-6">
        <p class="mb-10 text-center text-xs font-bold uppercase tracking-[0.2em] text-muted-foreground">
          Trusted by businesses in Karachi, Lahore & Islamabad
        </p>
        <div class="flex flex-wrap items-center justify-center gap-12 opacity-40 md:gap-24">
          <div class="text-2xl font-black">TECH-PK</div>
          <div class="text-2xl font-black italic">IndusGlobal</div>
          <div class="text-2xl font-black tracking-widest">ZINC</div>
          <div class="text-2xl font-black uppercase">Noor.Dev</div>
          <div class="font-serif text-2xl italic">Sahara&Co</div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section id="faq" class="relative overflow-hidden border-y border-border bg-muted/40 py-24">
      <div class="pointer-events-none absolute -right-32 top-10 h-96 w-96 rounded-full bg-brand-primary/10 blur-3xl"></div>

      <div class="relative mx-auto max-w-5xl px-6">
        <div class="mb-14 max-w-2xl space-y-5">
          <span class="text-xs font-bold uppercase tracking-[0.25em] text-brand-primary">FAQ</span>
          <p class="text-3xl font-bold leading-tight tracking-tight text-brand-secondary sm:text-4xl">
            Aap ke <span class="font-serif italic text-brand-primary">sawaalaat</span>, seedhe jawab.
          </p>
          <p class="text-base text-muted-foreground sm:text-lg">
            Pakistani clients ke aksar poochhe gaye sawalaat — pricing, timeline, SEO aur post-launch support ke baare mein.
          </p>
        </div>

        <div class="space-y-4">
          {FAQS.map((f, i) => (
            <details
              open={i === 0}
              class="group rounded-2xl border border-border bg-card p-6 shadow-sm transition-all hover:border-brand-primary/30 hover:shadow-elegant"
            >
              <summary class="flex cursor-pointer list-none items-start justify-between gap-4">
                <div class="space-y-1">
                  <div class="text-base font-bold text-brand-secondary sm:text-lg">{f.q}</div>
                  <div class="text-xs font-medium uppercase tracking-wider text-muted-foreground">{f.qEn}</div>
                </div>
                <span
                  aria-hidden="true"
                  class="mt-1 grid h-8 w-8 shrink-0 place-items-center rounded-full border border-border bg-background text-brand-primary transition-transform duration-300 group-open:rotate-45 group-open:border-brand-primary group-open:bg-brand-primary group-open:text-white"
                >
                  +
                </span>
              </summary>
              <div class="mt-4 animate-fade-in border-t border-border pt-4 text-base leading-relaxed text-muted-foreground">
                {f.a}
              </div>
            </details>
          ))}
        </div>

        <div class="mt-10 flex flex-col items-center justify-between gap-4 rounded-2xl border border-brand-primary/10 bg-brand-primary/5 px-6 py-5 sm:flex-row">
          <p class="text-center font-serif text-lg italic text-brand-secondary sm:text-left">
            Koi aur sawal hai? WhatsApp par 2 ghante mein jawab.
          </p>
          <a
            href="https://wa.me/923431015961?text=Assalam-o-Alaikum%2C%20mera%20ek%20sawal%20hai."
            target="_blank"
            rel="noreferrer"
            class="inline-flex shrink-0 items-center gap-2 rounded-xl bg-whatsapp px-5 py-3 text-sm font-bold text-white shadow-lg shadow-whatsapp/25 transition-all hover:brightness-110"
          >
            Ask on WhatsApp →
          </a>
        </div>
      </div>
    </section>

    <SiteFooter />

  </div>
</Layout>
