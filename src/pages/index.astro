---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import ProcessSteps from '../components/ProcessSteps.tsx';
import heroImage from '../assets/hero-workspace.jpg';
import blogImage from '../assets/blog-seo.jpg';
import { getCollection } from 'astro:content';
import { WHATSAPP_URL } from '../config';

const allPosts = await getCollection('blog');
const featuredPost = allPosts[0];
const marketplaceItems = await getCollection('marketplace');
const featuredMarketplaceItems = [...marketplaceItems]
  .sort((a, b) => Number(b.data.featured) - Number(a.data.featured))
  .slice(0, 3);

const CASE_STUDIES = [
  {
    client: "Raza Textiles",
    city: "Faisalabad",
    category: "E-commerce SEO",
    result: "+312% organic traffic",
    challenge: "Needed a storefront that felt more credible and was easier to browse on mobile.",
    approach: "Reworked category structure, simplified product discovery, and improved load speed across key pages.",
  },
  {
    client: "Lahore Estates",
    city: "Lahore",
    category: "Local SEO + Web",
    result: "#1 for 24 local keywords",
    challenge: "The business needed better local visibility and clearer lead-generation pages for property buyers.",
    approach: "Built targeted service pages, improved internal linking, and tightened the inquiry flow for faster conversions.",
  },
  {
    client: "Bloom Studio",
    city: "Karachi",
    category: "Performance Refresh",
    result: "4.2s to 0.9s on 4G",
    challenge: "The site looked good visually but felt slow and fragile on typical mobile connections.",
    approach: "Reduced unnecessary weight, improved asset delivery, and made the reading experience cleaner on small screens.",
  },
];

const PRICING = [
  {
    name: "Starter",
    price: "Rs. 15,000",
    unit: "one-time",
    desc: "For new businesses needing a fast, credible online presence.",
    features: ["5-page custom website", "Mobile responsive", "Basic on-page SEO", "WhatsApp integration", "2 weeks delivery"],
    popular: false,
  },
  {
    name: "Professional",
    price: "Rs. 30,000",
    unit: "one-time",
    desc: "For growing brands ready to dominate Google and convert at scale.",
    features: ["Full e-commerce / custom build", "Advanced SEO campaign", "Speed & Core Web Vitals", "1 month priority support", "Conversion-focused design"],
    popular: true,
  },
  {
    name: "Growth Retainer",
    price: "Rs. 50,000",
    unit: "per month",
    desc: "Ongoing SEO and growth partnership for serious operators.",
    features: ["Monthly SEO execution", "Content & backlink strategy", "Performance reports", "Unlimited small edits", "Dedicated WhatsApp line"],
    popular: false,
  },
];

const TESTIMONIALS = [
  {
    quote: "Irfan delivered our e-commerce store in record time. Our local sales jumped 40% in the first month alone thanks to his SEO strategy.",
    name: "Ahmed Raza",
    role: "CEO, Raza Textiles",
    initials: "AR",
  },
  {
    quote: "Finally, a developer in Pakistan who understands both the technical side and the local market. Communication on WhatsApp was instant.",
    name: "Fatima Khan",
    role: "Founder, Bloom Studio",
    initials: "FK",
  },
];

const RECENT_PROJECTS = [
  {
    name: "Raza Textiles Storefront",
    category: "E-commerce Build",
    summary: "A faster storefront for a Faisalabad textile seller, focused on mobile shopping and clearer product navigation.",
    outcome: "+312% organic growth",
    detail: "Improved category structure, speed, and product page clarity for lower-friction buying.",
  },
  {
    name: "Lahore Estates Lead Site",
    category: "Local SEO + Web",
    summary: "A lead-generation site for a real estate business that needed stronger local search visibility and trust.",
    outcome: "#1 for 24 local keywords",
    detail: "Rebuilt the service pages, localized landing pages, and simplified conversion paths.",
  },
  {
    name: "Bloom Studio Refresh",
    category: "Performance Upgrade",
    summary: "A Karachi creative business site redesigned to load fast on 4G and feel more premium on first visit.",
    outcome: "0.9s load on 4G",
    detail: "Reduced visual clutter, improved asset loading, and strengthened mobile readability.",
  },
];

const TRUST_POINTS = [
  {
    icon: "fa-solid fa-sack-dollar",
    title: "PKR-first pricing",
    desc: "No confusing currency games. Pakistani clients see real local pricing from the start.",
  },
  {
    icon: "fa-brands fa-whatsapp",
    title: "WhatsApp-first communication",
    desc: "Fast replies, clear updates, and no agency-style silence during the project.",
  },
  {
    icon: "fa-solid fa-mobile-screen-button",
    title: "Built for real internet conditions",
    desc: "The site experience is tuned for mobile use and 4G-heavy browsing habits.",
  },
];

const ABOUT_POINTS = [
  "Clear communication without agency jargon or confusing process talk.",
  "Mobile-first execution because most real users in Pakistan browse on phones.",
  "A practical mix of design, performance, and SEO so the site actually helps the business grow.",
];

const FAQS = [
  {
    q: "Aap ki pricing PKR mein hai ya USD?",
    a: "Sab pricing PKR mein hai — koi hidden currency conversion nahi. Starter package Rs. 15,000 se shuru hota hai. Bank transfer, Easypaisa, JazzCash — sab accept hain.",
  },
  {
    q: "Website banane mein kitna time lagta hai?",
    a: "Starter sites 1–2 hafton mein, full custom e-commerce 3–4 hafton mein launch ho jati hain. Aap ko weekly preview milti hai — koi guesswork nahi.",
  },
  {
    q: "Kya SEO ki guarantee dete hain ke main #1 aaunga?",
    a: "Honest jawab: koi bhi 'guaranteed #1' wala SEO expert jhoot bolta hai. Hum aap ko realistic targets dete hain, monthly reports bhejte hain, aur 3–6 mahine mein measurable growth dikhate hain.",
  },
  {
    q: "Kya aap WordPress kar sakte hain ya sirf custom code?",
    a: "Dono. Agar aap ka budget ya team WordPress ke saath comfortable hai, hum WordPress karein ge. High-performance ya unique features chahiye to Next.js / custom build best hai.",
  },
  {
    q: "Project ke baad support milta hai?",
    a: "Har project ke saath 1 month free support included hai — bug fixes, small edits, hosting help. Uske baad Growth Retainer mein unlimited edits + SEO included hain.",
  },
  {
    q: "Kya aap Pakistan ke bahar clients ke saath bhi kaam karte hain?",
    a: "Bilkul. UAE, UK, USA aur Canada ke Pakistani-owned businesses ke saath regularly kaam karte hain. Pricing USD mein adjust kar lete hain.",
  },
];

function formatMarketplacePrice(item: typeof marketplaceItems[number]) {
  if (item.data.price.free) return 'Free';
  return `Rs. ${item.data.price.pkr?.toLocaleString() ?? '—'}`;
}
---

<Layout
  title="Irfan — Web Development & SEO Expert in Pakistan"
  description="Premium web development and technical SEO for ambitious Pakistani businesses. All-in-one digital growth partner based in Lahore."
  ogTitle="Irfan — Web Development & SEO Expert in Pakistan"
  ogDescription="Premium web development and technical SEO for ambitious Pakistani businesses."
  ogImage={heroImage.src}
>
  <div class="min-h-screen bg-background font-sans text-brand-secondary">

    <SiteNav />

    <!-- Hero -->
    <header id="top" class="relative overflow-hidden px-0 pt-4 sm:px-6 sm:pt-6">
      <div aria-hidden="true" class="pointer-events-none absolute inset-0 overflow-hidden">
        <span class="hero-watermark hero-watermark-top">پاکستان</span>
        <span class="hero-watermark hero-watermark-bottom">ترقی</span>
      </div>
      <div class="section-shell mx-auto grid min-h-[calc(100svh-6.5rem)] max-w-none items-center gap-7 overflow-hidden rounded-none px-3 pb-8 pt-5 sm:max-w-[72rem] sm:rounded-[0.5rem] sm:px-10 sm:pb-12 sm:pt-12 lg:grid-cols-[1.1fr_0.9fr] lg:gap-14 lg:px-14 lg:py-16">

        <div class="space-y-5 sm:space-y-8">
          <div class="space-y-3 sm:space-y-4">
            <h1 class="text-balance text-4xl font-bold leading-[1.06] tracking-[-0.02em] text-brand-secondary sm:text-5xl lg:text-[3.6rem]">
              A website that feels <span class="text-brand-primary">expensive, calm,</span> and deeply local.
            </h1>
            <p class="text-support max-w-xl text-base leading-relaxed sm:text-lg">
              Premium web development aur technical SEO for Pakistani businesses that want trust, clarity, and real commercial results — not just a trendy landing page.
            </p>
          </div>

          <div class="flex flex-wrap items-center gap-3">
            <a
              href={WHATSAPP_URL}
              target="_blank"
              rel="noreferrer"
              class="inline-flex w-full items-center justify-center gap-2.5 rounded-lg bg-whatsapp px-6 py-3.5 text-sm font-bold text-white shadow-sm transition-all hover:brightness-110 sm:w-auto"
            >
              <i class="fa-brands fa-whatsapp text-base" aria-hidden="true"></i>
              WhatsApp Karein
            </a>
          </div>

        </div>

        <div>
          <div class="relative overflow-hidden rounded-[0.6rem]">
            <img
              src={heroImage.src}
              alt="Modern workspace with laptop showing a website design"
              width={1024}
              height={1280}
              class="aspect-[4/5] w-full object-cover"
            />
          </div>
        </div>
      </div>
    </header>

    <!-- Services -->
    <section id="solutions" class="bg-[#f7f3ea] px-3 py-20 sm:px-6">
      <div class="mx-auto max-w-[72rem] px-0 sm:px-2">
        <div class="mb-12 text-center">
          <span class="section-kicker text-xs font-bold uppercase text-brand-primary">Solutions</span>
          <h2 class="mt-2 text-3xl font-bold tracking-tight text-brand-secondary sm:text-4xl">Services shaped for trust, speed, and conversion.</h2>
          <p class="text-support mx-auto mt-3 max-w-2xl text-base leading-relaxed">
            Clean structure, clear value, and less visual noise. Every part should help a visitor understand what you do and why they should trust you.
          </p>
        </div>
        <div class="grid gap-6 md:grid-cols-3">

          <div class="ui-card rounded-[0.5rem] p-7">
            <span class="mb-5 grid h-12 w-12 place-items-center rounded-lg bg-brand-primary/10 text-lg text-brand-primary">
              <i class="fa-solid fa-code" aria-hidden="true"></i>
            </span>
            <h3 class="mb-3 text-lg font-bold text-brand-secondary">Custom Web Development</h3>
            <p class="text-support mb-5 text-sm leading-relaxed">High-performance builds engineered for speed, trust, and a polished first impression on every screen.</p>
            <ul class="space-y-2.5 text-sm text-brand-secondary/80">
              <li class="flex items-start gap-2.5"><i class="fa-solid fa-check mt-1 text-xs text-brand-primary" aria-hidden="true"></i>E-commerce integration</li>
              <li class="flex items-start gap-2.5"><i class="fa-solid fa-check mt-1 text-xs text-brand-primary" aria-hidden="true"></i>Optimized for 4G and low-latency users</li>
              <li class="flex items-start gap-2.5"><i class="fa-solid fa-check mt-1 text-xs text-brand-primary" aria-hidden="true"></i>Thoughtful admin and content flows</li>
            </ul>
          </div>

          <div class="ui-card rounded-[0.5rem] p-7">
            <span class="mb-5 grid h-12 w-12 place-items-center rounded-lg bg-brand-primary/10 text-lg text-brand-primary">
              <i class="fa-solid fa-magnifying-glass-chart" aria-hidden="true"></i>
            </span>
            <h3 class="mb-3 text-lg font-bold text-brand-secondary">Elite SEO Strategy</h3>
            <p class="text-support mb-5 text-sm leading-relaxed">We don’t just rank. We shape pages and search presence so your business feels credible before the first message arrives.</p>
            <ul class="space-y-2.5 text-sm text-brand-secondary/80">
              <li class="flex items-start gap-2.5"><i class="fa-solid fa-check mt-1 text-xs text-brand-primary" aria-hidden="true"></i>Competitor analysis by city and niche</li>
              <li class="flex items-start gap-2.5"><i class="fa-solid fa-check mt-1 text-xs text-brand-primary" aria-hidden="true"></i>Content strategy with local intent</li>
              <li class="flex items-start gap-2.5"><i class="fa-solid fa-check mt-1 text-xs text-brand-primary" aria-hidden="true"></i>On-page structure that supports conversion</li>
            </ul>
          </div>

          <div class="ui-card rounded-[0.5rem] p-7">
            <span class="mb-5 grid h-12 w-12 place-items-center rounded-lg bg-brand-primary/10 text-lg text-brand-primary">
              <i class="fa-solid fa-arrows-rotate" aria-hidden="true"></i>
            </span>
            <h3 class="mb-3 text-lg font-bold text-brand-secondary">Managed Growth</h3>
            <p class="text-support mb-5 text-sm leading-relaxed">Continuous support so your site stays fast, secure, and emotionally reassuring after launch too.</p>
            <ul class="space-y-2.5 text-sm text-brand-secondary/80">
              <li class="flex items-start gap-2.5"><i class="fa-solid fa-check mt-1 text-xs text-brand-primary" aria-hidden="true"></i>Security and updates</li>
              <li class="flex items-start gap-2.5"><i class="fa-solid fa-check mt-1 text-xs text-brand-primary" aria-hidden="true"></i>Monthly performance reporting</li>
              <li class="flex items-start gap-2.5"><i class="fa-solid fa-check mt-1 text-xs text-brand-primary" aria-hidden="true"></i>Conversion-focused iteration</li>
            </ul>
          </div>

        </div>
      </div>
    </section>

    <!-- About -->
    <section class="bg-white py-20">
      <div class="mx-auto grid max-w-[72rem] gap-8 px-3 sm:px-6 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
        <div>
          <span class="section-kicker text-xs font-bold uppercase text-brand-primary">About Us</span>
          <h2 class="mt-2 text-3xl font-bold tracking-tight text-brand-secondary sm:text-4xl">
            A practical growth partner for businesses that need more than just a pretty website.
          </h2>
        </div>
        <div class="space-y-5">
          <p class="text-support text-base leading-relaxed sm:text-lg">
            I build websites, landing pages, and SEO systems for Pakistani businesses that want clarity, trust, and measurable results. The work is not about trends or visual noise. It is about helping a business look credible, load fast, and convert better.
          </p>
          <p class="text-support text-base leading-relaxed sm:text-lg">
            The process stays intentionally simple: understand the business, improve the customer journey, and build pages that perform well on mobile and search. That means fewer wasted steps, stronger communication, and work that feels useful from day one.
          </p>
          <div class="grid gap-3">
            {ABOUT_POINTS.map((point) => (
              <div class="ui-card flex items-start gap-3 rounded-[0.5rem] p-4">
                <span class="mt-0.5 grid h-8 w-8 shrink-0 place-items-center rounded-full bg-brand-primary/10 text-brand-primary">
                  <i class="fa-solid fa-check text-xs" aria-hidden="true"></i>
                </span>
                <p class="text-sm leading-relaxed text-soft-strong">{point}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Case Studies -->
    <section id="results" class="bg-white py-20">
      <div class="mx-auto max-w-[72rem] px-3 sm:px-6">
        <div class="mb-12 text-center">
          <span class="section-kicker text-xs font-bold uppercase text-brand-primary">Case Studies</span>
          <h2 class="mt-2 text-3xl font-bold text-brand-secondary sm:text-4xl">
            Real businesses. Clear problems. <span class="text-brand-primary">Measured outcomes</span>.
          </h2>
          <p class="text-support mx-auto mt-3 max-w-2xl text-base leading-relaxed">
            A few examples of how the work translates into better speed, stronger trust, and more useful business results.
          </p>
        </div>
        <div class="grid gap-6 md:grid-cols-3">
          {CASE_STUDIES.map((study) => (
            <article class="ui-card rounded-[0.5rem] p-6">
              <div class="mb-5 flex items-start justify-between gap-3">
                <div>
                  <div class="text-xs font-bold uppercase tracking-widest text-muted-foreground">{study.category}</div>
                  <h3 class="mt-2 text-xl font-bold leading-tight tracking-tight text-brand-secondary">{study.client}</h3>
                  <div class="mt-1 text-xs uppercase tracking-[0.14em] text-soft-strong">{study.city}</div>
                </div>
                <span class="soft-chip inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-[10px] font-bold uppercase tracking-[0.14em] text-brand-primary">
                  <i class="fa-solid fa-arrow-trend-up" aria-hidden="true"></i>
                  Outcome
                </span>
              </div>

              <div class="mb-5 text-2xl font-bold tracking-tight text-brand-primary">
                {study.result}
              </div>

              <div class="space-y-4 border-t border-border pt-4">
                <div>
                  <div class="text-[0.72rem] font-bold uppercase tracking-[0.14em] text-brand-primary">Challenge</div>
                  <p class="text-support mt-1.5 text-sm leading-relaxed">{study.challenge}</p>
                </div>
                <div>
                  <div class="text-[0.72rem] font-bold uppercase tracking-[0.14em] text-brand-primary">What changed</div>
                  <p class="text-soft-strong mt-1.5 text-sm leading-relaxed">{study.approach}</p>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Recent Projects -->
    <section class="bg-[#f7f3ea] py-20">
      <div class="mx-auto max-w-[72rem] px-3 sm:px-6">
        <div class="mb-12 text-center">
          <span class="section-kicker text-xs font-bold uppercase text-brand-primary">Recent Projects</span>
          <h2 class="mt-2 text-3xl font-bold text-brand-secondary sm:text-4xl">
            Recent work that solved <span class="text-brand-primary">real business problems</span>.
          </h2>
          <p class="text-support mx-auto mt-3 max-w-2xl text-base leading-relaxed">
            Not just pretty layouts. These are projects shaped around speed, trust, and better conversion for actual Pakistani businesses.
          </p>
        </div>
        <div class="grid gap-6 md:grid-cols-3">
          {RECENT_PROJECTS.map((project) => (
            <article class="ui-card rounded-[0.5rem] p-6">
              <div class="mb-4 flex items-center justify-between gap-3">
                <span class="soft-chip rounded-full px-3 py-1 text-[10px] font-bold uppercase tracking-[0.14em] text-brand-primary">
                  {project.category}
                </span>
                <span class="text-sm font-bold text-brand-primary">{project.outcome}</span>
              </div>
              <h3 class="text-xl font-bold leading-tight tracking-tight text-brand-secondary">{project.name}</h3>
              <p class="text-support mt-3 text-sm leading-relaxed">{project.summary}</p>
              <p class="mt-5 border-t border-border pt-4 text-sm leading-relaxed text-soft-strong">{project.detail}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Process -->
    <section id="process" class="bg-[#f6f1e7] py-20">
      <div class="mx-auto max-w-[72rem] px-3 sm:px-6">
        <div class="mb-12 text-center">
          <span class="section-kicker text-xs font-bold uppercase text-brand-primary">The Process</span>
          <h2 class="mt-2 text-3xl font-bold text-brand-secondary sm:text-4xl">
            Simple, transparent, on-time.
          </h2>
          <p class="text-support mx-auto mt-3 max-w-xl text-base">
            Char asaan steps — har step par aap ko poori update milti hai. Koi confusion, koi hidden charges nahi.
          </p>
        </div>
        <ProcessSteps client:load />
      </div>
    </section>

    <!-- Pricing -->
    <section id="pricing" class="bg-white py-20">
      <div class="mx-auto max-w-[72rem] px-3 sm:px-6">
        <div class="mb-12 text-center">
          <span class="section-kicker text-xs font-bold uppercase text-brand-primary">Pricing</span>
          <h2 class="mt-2 text-3xl font-bold text-brand-secondary sm:text-4xl">
            Transparent rates. <span class="text-brand-primary">All in PKR</span>.
          </h2>
        </div>
        <div class="grid gap-6 md:grid-cols-3">
          {PRICING.map((t) => (
            <div class={t.popular
              ? "ui-card relative rounded-[0.5rem] border-brand-primary p-8"
              : "ui-card rounded-[0.5rem] p-8"
            }>
              {t.popular && (
                <div class="absolute -top-3 right-6 rounded-full bg-brand-primary px-3 py-1 text-[10px] font-bold uppercase tracking-widest text-white">
                  Most Popular
                </div>
              )}
              <h3 class="text-lg font-bold text-brand-secondary">{t.name}</h3>
              <div class="mt-3 flex items-baseline gap-2">
                <span class="text-3xl font-bold tracking-tight">{t.price}</span>
                <span class="text-soft-strong text-xs">/{t.unit}</span>
              </div>
              <p class="text-support mt-3 text-sm">{t.desc}</p>
              <ul class="mt-6 space-y-3 text-sm">
                {t.features.map((f) => (
                  <li class="flex items-start gap-2.5 text-brand-secondary">
                    <i class="fa-solid fa-check mt-1 shrink-0 text-xs text-brand-primary" aria-hidden="true"></i> {f}
                  </li>
                ))}
              </ul>
              <a
                href={WHATSAPP_URL}
                target="_blank"
                rel="noreferrer"
                class={t.popular
                  ? "mt-7 block rounded-lg bg-brand-primary py-3 text-center text-sm font-bold text-white transition-all hover:bg-brand-secondary"
                  : "mt-7 block rounded-lg border border-brand-primary/20 py-3 text-center text-sm font-bold transition-all hover:bg-brand-primary hover:border-transparent hover:text-white"
                }
              >
                Get Started
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Featured Marketplace -->
    <section class="bg-white py-20">
      <div class="mx-auto max-w-[72rem] px-3 sm:px-6">
        <div class="mb-12 flex flex-col items-center gap-4 text-center sm:flex-row sm:items-end sm:justify-between sm:text-left">
          <div>
            <span class="section-kicker text-xs font-bold uppercase text-brand-primary">Featured Marketplace</span>
            <h2 class="mt-2 text-3xl font-bold text-brand-secondary sm:text-4xl">
              Useful digital products for <span class="text-brand-primary">faster execution</span>.
            </h2>
            <p class="text-support mt-3 max-w-2xl text-base leading-relaxed">
              Ready-to-use templates, checklists, and systems for businesses that want practical progress without starting from zero.
            </p>
          </div>
          <a
            href="/marketplace"
            class="inline-flex items-center gap-2 rounded-full border border-border px-5 py-2.5 text-sm font-bold text-brand-secondary transition-colors hover:border-brand-primary hover:text-brand-primary"
          >
            Browse marketplace
            <i class="fa-solid fa-arrow-right text-xs" aria-hidden="true"></i>
          </a>
        </div>
        <div class="grid gap-6 md:grid-cols-3">
          {featuredMarketplaceItems.map((item) => (
            <article class="ui-card rounded-[0.5rem] p-6">
              <div class="mb-4 flex items-center justify-between gap-3">
                <span class="soft-chip rounded-full px-3 py-1 text-[10px] font-bold uppercase tracking-[0.14em] text-brand-primary">
                  {item.data.category}
                </span>
                <span class={`text-sm font-bold ${item.data.price.free ? 'text-whatsapp' : 'text-brand-primary'}`}>
                  {formatMarketplacePrice(item)}
                </span>
              </div>
              <h3 class="text-xl font-bold leading-tight tracking-tight text-brand-secondary">{item.data.name}</h3>
              <p class="text-support mt-3 text-sm leading-relaxed">{item.data.tagline}</p>
              <div class="mt-5 flex flex-wrap gap-2">
                {item.data.tags.slice(0, 3).map((tag) => (
                  <span class="rounded-full border border-border px-2.5 py-1 text-[10px] font-semibold text-soft-strong">
                    {tag}
                  </span>
                ))}
              </div>
              <div class="mt-6 border-t border-border pt-4">
                <a
                  href="/marketplace"
                  class="inline-flex items-center gap-2 text-sm font-bold text-brand-primary transition-colors hover:text-accent"
                >
                  View in marketplace
                  <i class="fa-solid fa-arrow-right text-xs" aria-hidden="true"></i>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Testimonials -->
    <section class="bg-[#f7f3ea] py-20">
      <div class="mx-auto max-w-[72rem] px-3 sm:px-6">
        <div class="mb-12 text-center">
          <span class="section-kicker text-xs font-bold uppercase text-brand-primary">Testimonials</span>
          <h2 class="mt-2 text-3xl font-bold text-brand-secondary sm:text-4xl">
            What clients actually <span class="text-brand-primary">feel</span>.
          </h2>
        </div>
        <div class="grid gap-6 md:grid-cols-2">
          {TESTIMONIALS.map((t) => (
            <div class="ui-card rounded-[0.5rem] p-8">
              <i class="fa-solid fa-quote-left mb-4 text-2xl text-brand-primary/25" aria-hidden="true"></i>
              <p class="text-lg font-semibold leading-relaxed text-brand-secondary">
                {t.quote}
              </p>
              <div class="mt-6 flex items-center gap-3">
                <div class="grid h-10 w-10 shrink-0 place-items-center rounded-full bg-brand-primary text-xs font-bold text-white">
                  {t.initials}
                </div>
                <div>
                  <p class="font-semibold text-brand-secondary">{t.name}</p>
                  <p class="text-soft-strong text-xs">{t.role}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Blog -->
    <section id="blog" class="bg-white py-20">
      <div class="mx-auto max-w-[72rem] px-3 sm:px-6">
        <div class="mb-12 flex flex-col items-center justify-center gap-5 text-center">
          <div>
            <span class="section-kicker text-xs font-bold uppercase text-brand-primary">From the Journal</span>
            <h2 class="mt-2 text-3xl font-bold text-brand-secondary sm:text-4xl">
              Ideas & SEO tips for<br />Pakistani businesses.
            </h2>
          </div>
          <a
            href="/blog"
            class="inline-flex items-center gap-2 rounded-full border border-border px-5 py-2.5 text-sm font-bold transition-all hover:border-brand-primary hover:text-brand-primary"
          >
            View all <i class="fa-solid fa-arrow-right text-xs" aria-hidden="true"></i>
          </a>
        </div>

        <article class="ui-card grid overflow-hidden rounded-[0.5rem] md:grid-cols-2">
          <a href={`/blog/${featuredPost.id}`} class="relative block overflow-hidden">
            <img
              src={blogImage.src}
              alt="SEO article thumbnail"
              width={1280}
              height={900}
              loading="lazy"
              class="aspect-[4/3] h-full w-full object-cover transition-transform duration-500 hover:scale-105"
            />
            <span class="soft-chip absolute left-4 top-4 inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-[10px] font-bold uppercase tracking-widest text-brand-primary">
              <i class="fa-solid fa-star text-[9px]" aria-hidden="true"></i>Featured
            </span>
          </a>
          <div class="flex flex-col justify-between p-8">
            <div class="space-y-4">
              <div class="flex flex-wrap items-center gap-2 text-xs text-muted-foreground">
                <span class="soft-chip rounded-full px-2.5 py-1 text-[10px] font-bold uppercase text-brand-primary">{featuredPost.data.category}</span>
                <span>{featuredPost.data.readMinutes} min read</span>
                <span>·</span>
                <span>{featuredPost.data.date}</span>
              </div>
              <h3 class="text-2xl font-bold leading-snug text-brand-secondary">
                {featuredPost.data.title}{" "}
                <span class="text-brand-primary">{featuredPost.data.titleAccent}</span>{" "}
                {featuredPost.data.titleTail}
              </h3>
              <p class="text-support text-sm leading-relaxed">{featuredPost.data.excerpt}</p>
            </div>
            <div class="mt-6 flex items-center justify-between border-t border-border pt-5">
              <div class="flex items-center gap-2.5">
                <div class="grid h-9 w-9 place-items-center rounded-full bg-brand-primary text-xs font-bold text-white">I</div>
                <div>
                  <div class="text-sm font-semibold text-brand-secondary">Irfan</div>
                  <div class="text-[10px] text-muted-foreground">Web + SEO</div>
                </div>
              </div>
              <a href={`/blog/${featuredPost.id}`} class="inline-flex items-center gap-2 text-sm font-bold text-brand-primary transition-colors hover:text-accent">
                Read <i class="fa-solid fa-arrow-right text-xs" aria-hidden="true"></i>
              </a>
            </div>
          </div>
        </article>
      </div>
    </section>

    <!-- Trust -->
    <section class="bg-[#f4efe6] py-16">
      <div class="mx-auto max-w-[72rem] px-3 sm:px-6">
        <div class="mb-10 text-center">
          <span class="section-kicker text-xs font-bold uppercase text-brand-primary">Why It Works</span>
          <h2 class="mt-2 text-3xl font-bold text-brand-secondary sm:text-4xl">
            Designed around how Pakistani clients <span class="text-brand-primary">actually buy</span>.
          </h2>
        </div>
        <div class="grid gap-6 md:grid-cols-3">
          {TRUST_POINTS.map((point) => (
            <div class="ui-card rounded-[0.5rem] p-7">
              <span class="mb-4 grid h-12 w-12 place-items-center rounded-lg bg-brand-primary/10 text-lg text-brand-primary">
                <i class={point.icon} aria-hidden="true"></i>
              </span>
              <h3 class="text-lg font-bold text-brand-secondary">{point.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-muted-foreground">{point.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section id="faq" class="bg-white py-20">
      <div class="mx-auto max-w-[72rem] px-3 sm:px-6">
        <div class="mb-12 text-center">
          <span class="section-kicker text-xs font-bold uppercase text-brand-primary">FAQ</span>
          <h2 class="mt-2 text-3xl font-bold text-brand-secondary sm:text-4xl">
            Aap ke sawaalaat, seedhe jawab.
          </h2>
          <p class="text-support mx-auto mt-3 max-w-2xl">
            Pricing, timeline, SEO aur post-launch support ke baare mein.
          </p>
        </div>

        <div class="grid gap-4 md:grid-cols-2 md:items-start">
          {FAQS.map((f, i) => (
            <details open={i === 0} class="ui-card group rounded-[0.5rem]">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-4 p-5">
                <span class="text-base font-semibold text-brand-secondary">{f.q}</span>
                <span
                  aria-hidden="true"
                  class="grid h-7 w-7 shrink-0 place-items-center rounded-full border border-border text-xs text-brand-primary transition-transform duration-200 group-open:rotate-45"
                >
                  <i class="fa-solid fa-plus"></i>
                </span>
              </summary>
              <div class="text-support border-t border-border px-5 pb-5 pt-4 text-sm leading-relaxed">
                {f.a}
              </div>
            </details>
          ))}
        </div>

        <div class="human-note mt-8 rounded-[0.5rem] p-6 text-center">
          <p class="text-support text-sm">Koi aur sawal hai?</p>
          <a
            href={WHATSAPP_URL}
            target="_blank"
            rel="noreferrer"
            class="mt-3 inline-flex items-center gap-2 rounded-lg bg-whatsapp px-5 py-2.5 text-sm font-bold text-white transition-all hover:brightness-110"
          >
            <i class="fa-brands fa-whatsapp text-base" aria-hidden="true"></i>Ask on WhatsApp
          </a>
        </div>
      </div>
    </section>

    <SiteFooter />

  </div>
</Layout>
