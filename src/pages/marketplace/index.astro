---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import SiteNav from '../../components/SiteNav.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import heroImage from '../../assets/hero-workspace.jpg';
import blogImage from '../../assets/blog-seo.jpg';
import { WHATSAPP_URL, WHATSAPP_NUMBER } from '../../config';

const products = await getCollection('marketplace');

const featured = products.filter((p) => p.data.featured);
const rest = products.filter((p) => !p.data.featured);
const sorted = [...featured, ...rest];

const freeCount = products.filter((p) => p.data.price.free).length;

const CATEGORY_COLORS: Record<string, string> = {
  Template:    'soft-chip text-brand-primary',
  Checklist:   'soft-chip text-brand-primary',
  Guide:       'soft-chip text-brand-primary',
  'UI Kit':    'soft-chip text-brand-primary',
  Spreadsheet: 'soft-chip text-brand-primary',
};

const FILTER_TABS = [
  { label: 'All', icon: 'fa-solid fa-border-all' },
  { label: 'Free', icon: 'fa-solid fa-gift' },
  { label: 'Template', icon: 'fa-regular fa-window-maximize' },
  { label: 'Checklist', icon: 'fa-solid fa-list-check' },
  { label: 'Guide', icon: 'fa-regular fa-compass' },
  { label: 'UI Kit', icon: 'fa-solid fa-cubes' },
  { label: 'Spreadsheet', icon: 'fa-regular fa-table-cells-large' },
];

function whatsappBuyUrl(name: string) {
  const msg = encodeURIComponent(
    `Assalam-o-Alaikum Irfan, I'd like to purchase "${name}". Please share payment details.`
  );
  return `https://wa.me/${WHATSAPP_NUMBER}?text=${msg}`;
}
---

<Layout
  title="Marketplace — Irfan | Digital Assets for Pakistani Businesses"
  description="Free and paid digital assets: SEO checklists, website templates, UI kits, and spreadsheet tools built for the Pakistani market."
  ogTitle="Marketplace — Irfan | Digital Assets"
  ogDescription="Free and paid digital assets: SEO checklists, website templates, UI kits, and spreadsheet tools built for the Pakistani market."
  ogImage={heroImage.src}
>
  <div class="min-h-screen bg-background font-sans text-brand-secondary">
    <SiteNav />

    <!-- Header -->
    <header class="px-0 pt-4 sm:px-6 sm:pt-6">
      <div class="page-hero-shell mx-auto max-w-none rounded-none px-3 py-8 sm:max-w-[72rem] sm:rounded-[0.6rem] sm:px-8 sm:py-14">
        <div aria-hidden="true" class="pointer-events-none absolute inset-0 overflow-hidden">
          <span class="page-watermark page-watermark-top">بازار</span>
          <span class="page-watermark page-watermark-bottom">وسائل</span>
        </div>
        <div class="relative z-10 text-center">
          <span class="section-kicker text-xs font-bold uppercase text-brand-primary">Marketplace</span>
          <h1 class="mx-auto mt-4 max-w-none text-4xl font-bold leading-tight tracking-tight text-brand-secondary sm:max-w-4xl sm:text-5xl md:text-[4.25rem]">
            Digital assets built for <span class="font-serif italic text-brand-primary sm:block">Pakistani businesses.</span>
          </h1>
          <p class="text-support mx-auto mt-4 max-w-2xl text-lg leading-relaxed">
            SEO checklists, website templates, UI kits, and tracking tools, now presented in the same calmer and more credible system as the homepage.
          </p>
        </div>
      </div>
    </header>

    <!-- Filter tabs -->
    <div class="sticky top-[78px] z-40 px-0 py-3 sm:px-6 sm:py-4">
      <div class="glass-nav mx-auto max-w-none rounded-none sm:max-w-[72rem] sm:rounded-[0.5rem]">
      <div class="mx-auto max-w-[72rem] overflow-x-auto px-3 sm:px-6">
        <div class="flex gap-2 py-3 sm:gap-1" id="filter-tabs" role="tablist">
          {FILTER_TABS.map((tab, i) => (
            <button
              type="button"
              role="tab"
              data-tab={tab.label}
              aria-selected={i === 0}
              class={`filter-tab shrink-0 rounded-full px-3.5 py-2 text-[0.72rem] font-semibold tracking-tight transition-all sm:px-4 sm:py-1.5 sm:text-xs sm:font-bold sm:uppercase sm:tracking-widest ${
                i === 0
                  ? 'bg-brand-primary text-white shadow-sm'
                  : 'border border-border/70 bg-[var(--input)] text-muted-foreground hover:bg-brand-primary/5 hover:text-brand-primary'
              }`}
            >
              <span class="inline-flex items-center gap-2">
                <i class={`${tab.icon} text-[0.8rem] sm:text-[0.72rem]`} aria-hidden="true"></i>
                <span>{tab.label}</span>
              </span>
            </button>
          ))}
        </div>
      </div>
      </div>
    </div>

    <!-- Product grid -->
    <main class="mx-auto max-w-[72rem] px-3 py-14 sm:px-6 sm:py-16">
      <div id="product-grid" class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {sorted.map((product) => {
          const { name, tagline, category, price, featured, downloadUrl } = product.data;
          const categoryClass = CATEGORY_COLORS[category] ?? 'bg-muted text-muted-foreground';
          const isFree = price.free;

          const previewImage = category === 'Template' || category === 'UI Kit' ? heroImage.src : blogImage.src;
          return (
            <article
              data-category={category}
              data-free={String(isFree)}
              class={`product-card group relative flex flex-col overflow-hidden rounded-[0.6rem] shadow-[0_1px_2px_rgba(8,35,28,0.04)] transition-all duration-300 hover:-translate-y-1.5 hover:shadow-elegant ${
                featured ? 'ui-card ring-1 ring-brand-primary/20' : 'ui-card'
              }`}
            >
              <!-- Cover -->
              <div class="relative overflow-hidden">
                <img
                  src={previewImage.src ?? previewImage}
                  alt={`${name} preview image`}
                  class="aspect-[16/10] w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-brand-secondary/25 to-transparent"></div>
                <span class={`absolute left-3 top-3 rounded-full px-2.5 py-1 text-[10px] font-bold uppercase tracking-widest backdrop-blur-sm ${categoryClass}`}>
                  {category}
                </span>
                {featured && (
                  <span class="soft-chip absolute right-3 top-3 inline-flex items-center gap-1.5 rounded-full px-2.5 py-1 text-[10px] font-bold uppercase tracking-widest text-brand-primary backdrop-blur-sm">
                    <i class="fa-solid fa-star text-[9px]" aria-hidden="true"></i>Featured
                  </span>
                )}
              </div>

              <!-- Body -->
              <div class="flex flex-1 flex-col p-5">
                <h2 class="text-lg font-bold leading-snug tracking-tight text-brand-secondary transition-colors group-hover:text-brand-primary">
                  {name}
                </h2>
                <p class="text-support mt-2 flex-1 text-sm leading-relaxed">
                  {tagline}
                </p>

                <!-- Price -->
                <div class="mt-4 flex items-baseline gap-2 border-t border-border pt-4">
                  {isFree ? (
                    <span class="text-base font-bold text-whatsapp">Free</span>
                  ) : (
                    <>
                      <span class="text-lg font-bold text-brand-secondary">Rs. {price.pkr?.toLocaleString() ?? '—'}</span>
                      <span class="text-xs font-medium text-muted-foreground">/ ${price.usd ?? '—'}</span>
                    </>
                  )}
                </div>

                <!-- CTA -->
                <div class="mt-3">
                {isFree ? (
                  downloadUrl && downloadUrl !== '#' ? (
                    <a
                      href={downloadUrl}
                      aria-label={`Download ${name} for free`}
                      class="flex w-full items-center justify-center gap-2 rounded-lg bg-brand-primary px-5 py-3 text-sm font-bold text-white shadow-sm transition-all hover:bg-brand-secondary"
                    >
                      <i class="fa-solid fa-download text-sm" aria-hidden="true"></i>
                      Download Free
                    </a>
                  ) : (
                    <span
                      aria-label={`${name} — coming soon`}
                      class="flex w-full cursor-not-allowed items-center justify-center gap-2 rounded-lg bg-muted px-5 py-3 text-sm font-bold text-muted-foreground"
                    >
                      <i class="fa-regular fa-clock text-sm" aria-hidden="true"></i>
                      Coming Soon
                    </span>
                  )
                ) : (
                  <a
                    href={whatsappBuyUrl(name)}
                    target="_blank"
                    rel="noreferrer"
                    aria-label={`Buy ${name} via WhatsApp`}
                    class="flex w-full items-center justify-center gap-2 rounded-lg bg-whatsapp px-5 py-3 text-sm font-bold text-white shadow-sm shadow-whatsapp/20 transition-all hover:brightness-110"
                  >
                    <i class="fa-brands fa-whatsapp text-base" aria-hidden="true"></i>
                    Buy via WhatsApp
                  </a>
                )}
                </div>
              </div>
            </article>
          );
        })}
      </div>

      <!-- Empty state (shown by JS when filter has no results) -->
      <div id="empty-state" class="hidden py-20 text-center">
        <p class="text-support">No assets in this category yet — check back soon.</p>
        <a href="/marketplace" class="mt-4 inline-block text-sm font-bold text-brand-primary hover:text-accent">
          View all assets <i class="fa-solid fa-arrow-right text-xs" aria-hidden="true"></i>
        </a>
      </div>
    </main>

    <!-- Bottom CTA -->
      <div class="mx-auto max-w-[72rem] px-6 pb-16">
      <div class="ui-card flex flex-col items-center justify-between gap-4 rounded-[0.5rem] px-6 py-5 sm:flex-row">
        <div>
          <p class="font-semibold text-brand-secondary">Need something custom?</p>
          <p class="text-support mt-1 text-sm">
            Custom SEO templates, website audits, or branded toolkits — let's discuss on WhatsApp.
          </p>
        </div>
        <a
          href={WHATSAPP_URL}
          target="_blank"
          rel="noreferrer"
          class="inline-flex shrink-0 items-center gap-2 rounded-lg bg-whatsapp px-5 py-3 text-sm font-bold text-white shadow-sm shadow-whatsapp/25 transition-all hover:brightness-110"
        >
          <i class="fa-brands fa-whatsapp text-base" aria-hidden="true"></i>WhatsApp Karein
        </a>
      </div>
    </div>

    <SiteFooter />
  </div>
</Layout>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.filter-tab');
  const cards = document.querySelectorAll<HTMLElement>('.product-card');
  const emptyState = document.getElementById('empty-state')!;

  function applyFilter(filter: string) {
    let visible = 0;
    cards.forEach((card) => {
      const category = card.dataset.category ?? '';
      const isFree = card.dataset.free === 'true';
      const show =
        filter === 'All' ||
        (filter === 'Free' && isFree) ||
        category === filter;
      card.classList.toggle('hidden', !show);
      if (show) visible++;
    });
    emptyState.classList.toggle('hidden', visible > 0);
  }

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      tabs.forEach((t) => {
        t.classList.remove('bg-brand-primary', 'text-white');
        t.classList.add('text-muted-foreground', 'hover:bg-brand-primary/5', 'hover:text-brand-primary');
        t.setAttribute('aria-selected', 'false');
      });
      tab.classList.add('bg-brand-primary', 'text-white');
      tab.classList.remove('text-muted-foreground', 'hover:bg-brand-primary/5', 'hover:text-brand-primary');
      tab.setAttribute('aria-selected', 'true');
      applyFilter(tab.dataset.tab ?? 'All');
    });
  });
</script>
