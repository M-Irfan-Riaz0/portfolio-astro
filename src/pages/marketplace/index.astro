---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import SiteNav from '../../components/SiteNav.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import heroImage from '../../assets/hero-workspace.jpg';
import { WHATSAPP_URL, WHATSAPP_NUMBER } from '../../config';

const products = await getCollection('marketplace');

const featured = products.filter((p) => p.data.featured);
const rest = products.filter((p) => !p.data.featured);
const sorted = [...featured, ...rest];

const freeCount = products.filter((p) => p.data.price.free).length;

const CATEGORY_COLORS: Record<string, string> = {
  Template:    'soft-chip text-brand-primary',
  Checklist:   'soft-chip text-brand-primary',
  Guide:       'soft-chip text-brand-primary',
  'UI Kit':    'soft-chip text-brand-primary',
  Spreadsheet: 'soft-chip text-brand-primary',
};

// Simple line-icon paths per category (drawn inside a 24x24 viewBox).
const CATEGORY_ICONS: Record<string, string> = {
  Template:    'M3 3h18v4H3zM3 11h10v10H3zM17 11h4v10h-4z',
  Checklist:   'M9 11l3 3 8-8M3 6h7M3 12h4M3 18h7',
  Guide:       'M4 4h11a3 3 0 0 1 3 3v13a2 2 0 0 0-2-2H4zM4 4v14',
  'UI Kit':    'M3 3h7v7H3zM14 3h7v7h-7zM14 14h7v7h-7zM3 14h7v7H3z',
  Spreadsheet: 'M3 3h18v18H3zM3 9h18M3 15h18M9 3v18M15 3v18',
};

function whatsappBuyUrl(name: string) {
  const msg = encodeURIComponent(
    `Assalam-o-Alaikum Irfan, I'd like to purchase "${name}". Please share payment details.`
  );
  return `https://wa.me/${WHATSAPP_NUMBER}?text=${msg}`;
}
---

<Layout
  title="Marketplace — Irfan | Digital Assets for Pakistani Businesses"
  description="Free and paid digital assets: SEO checklists, website templates, UI kits, and spreadsheet tools built for the Pakistani market."
  ogTitle="Marketplace — Irfan | Digital Assets"
  ogDescription="Free and paid digital assets: SEO checklists, website templates, UI kits, and spreadsheet tools built for the Pakistani market."
  ogImage={heroImage.src}
>
  <div class="min-h-screen bg-background font-sans text-brand-secondary">
    <SiteNav />

    <!-- Header -->
    <header class="px-6 pt-6">
      <div class="page-hero-shell mx-auto max-w-7xl rounded-[2.5rem] px-6 py-14 sm:px-8 sm:py-16">
        <div aria-hidden="true" class="pointer-events-none absolute inset-0 overflow-hidden">
          <span class="page-watermark page-watermark-top">بازار</span>
          <span class="page-watermark page-watermark-bottom">وسائل</span>
        </div>
        <div class="relative z-10">
          <span class="section-kicker text-xs font-bold uppercase text-brand-primary">Marketplace</span>
          <h1 class="mt-4 max-w-3xl text-4xl font-bold leading-tight tracking-tight text-brand-secondary sm:text-5xl md:text-6xl">
            Digital assets built for<br />
            <span class="font-serif italic text-brand-primary">Pakistani businesses.</span>
          </h1>
          <p class="mt-4 max-w-2xl text-lg leading-relaxed text-muted-foreground">
            SEO checklists, website templates, UI kits, and tracking tools, now presented in the same calmer and more credible system as the homepage.
          </p>
          <div class="mt-8 grid gap-4 sm:grid-cols-3">
            <div class="ui-card rounded-[1.5rem] p-5">
              <div class="text-2xl font-bold text-brand-secondary">{products.length}</div>
              <div class="mt-1 text-xs uppercase tracking-[0.16em] text-muted-foreground">Assets available</div>
            </div>
            <div class="ui-card rounded-[1.5rem] p-5">
              <div class="text-2xl font-bold text-brand-secondary">{freeCount}</div>
              <div class="mt-1 text-xs uppercase tracking-[0.16em] text-muted-foreground">Completely free</div>
            </div>
            <div class="ui-card rounded-[1.5rem] p-5">
              <div class="text-2xl font-bold text-brand-secondary">Instant</div>
              <div class="mt-1 text-xs uppercase tracking-[0.16em] text-muted-foreground">Delivery</div>
            </div>
          </div>
        </div>
      </div>
    </header>

    <!-- Filter tabs -->
    <div class="sticky top-[88px] z-40 px-6 py-4">
      <div class="glass-nav mx-auto max-w-7xl rounded-[1.6rem]">
      <div class="mx-auto max-w-7xl overflow-x-auto px-6">
        <div class="flex gap-1 py-3" id="filter-tabs" role="tablist">
          {['All', 'Free', 'Template', 'Checklist', 'Guide', 'UI Kit', 'Spreadsheet'].map((tab, i) => (
            <button
              type="button"
              role="tab"
              data-tab={tab}
              aria-selected={i === 0}
              class={`filter-tab shrink-0 rounded-full px-4 py-1.5 text-xs font-bold uppercase tracking-widest transition-all ${
                i === 0
                  ? 'bg-brand-primary text-white'
                  : 'text-muted-foreground hover:bg-brand-primary/5 hover:text-brand-primary'
              }`}
            >
              {tab}
            </button>
          ))}
        </div>
      </div>
      </div>
    </div>

    <!-- Product grid -->
    <main class="mx-auto max-w-7xl px-6 py-16">
      <div id="product-grid" class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {sorted.map((product) => {
          const { name, tagline, category, price, tags, featured, downloadUrl } = product.data;
          const categoryClass = CATEGORY_COLORS[category] ?? 'bg-muted text-muted-foreground';
          const isFree = price.free;
          const priceLabel = isFree
            ? 'Free'
            : `Rs. ${price.pkr?.toLocaleString() ?? '—'} / $${price.usd ?? '—'}`;

          const iconPath = CATEGORY_ICONS[category];
          return (
            <article
              data-category={category}
              data-free={String(isFree)}
              class={`product-card group relative flex flex-col rounded-[1.5rem] p-7 transition-all duration-200 hover:border-brand-primary/30 ${
                featured ? 'ui-card border-brand-primary/30 ring-1 ring-brand-primary/10' : 'ui-card'
              }`}
            >
              {featured && (
                <span class="absolute right-5 top-5 rounded-full bg-brand-primary px-3 py-1 text-[10px] font-bold uppercase tracking-widest text-white">
                  Featured
                </span>
              )}

              <!-- Top row: category icon + price -->
              <div class="mb-5 flex items-start justify-between gap-3">
                <div class="flex items-center gap-2.5">
                  <span class={`grid h-9 w-9 shrink-0 place-items-center rounded-xl ${categoryClass}`}>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-[18px] w-[18px]" aria-hidden="true">
                      <path d={iconPath} />
                    </svg>
                  </span>
                  <span class={`rounded-full px-2.5 py-1 text-[10px] font-bold uppercase tracking-widest ${categoryClass}`}>
                    {category}
                  </span>
                </div>
                <span class={`shrink-0 rounded-full px-3 py-1 text-[10px] font-bold ${
                  isFree
                    ? 'bg-whatsapp/10 text-whatsapp'
                    : 'bg-brand-primary/10 text-brand-primary'
                }`}>
                  {priceLabel}
                </span>
              </div>

              <h2 class="mb-2 pr-20 text-xl font-bold leading-tight tracking-tight text-brand-secondary transition-colors group-hover:text-brand-primary">
                {name}
              </h2>
              <p class="mb-5 flex-1 text-sm leading-relaxed text-muted-foreground">
                {tagline}
              </p>

              <!-- Tags -->
              <div class="mb-6 flex flex-wrap gap-2">
                {tags.map((tag) => (
                  <span class="rounded-full border border-border px-2 py-0.5 text-[10px] font-semibold text-muted-foreground">
                    {tag}
                  </span>
                ))}
              </div>

              <!-- CTA -->
              <div class="border-t border-border pt-5">
                {isFree ? (
                  downloadUrl && downloadUrl !== '#' ? (
                    <a
                      href={downloadUrl}
                      aria-label={`Download ${name} for free`}
                      class="flex w-full items-center justify-center gap-2 rounded-xl bg-brand-primary px-5 py-3 text-sm font-bold text-white shadow-sm transition-all hover:bg-brand-secondary"
                    >
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="h-4 w-4" aria-hidden="true">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                        <polyline points="7 10 12 15 17 10" />
                        <line x1="12" y1="15" x2="12" y2="3" />
                      </svg>
                      Download Free
                    </a>
                  ) : (
                    <span
                      aria-label={`${name} — coming soon`}
                      class="flex w-full cursor-not-allowed items-center justify-center gap-2 rounded-xl bg-muted px-5 py-3 text-sm font-bold text-muted-foreground"
                    >
                      Coming Soon
                    </span>
                  )
                ) : (
                  <a
                    href={whatsappBuyUrl(name)}
                    target="_blank"
                    rel="noreferrer"
                    aria-label={`Buy ${name} via WhatsApp`}
                    class="flex w-full items-center justify-center gap-2 rounded-xl bg-whatsapp px-5 py-3 text-sm font-bold text-white shadow-sm shadow-whatsapp/20 transition-all hover:brightness-110"
                  >
                    <svg viewBox="0 0 24 24" class="h-4 w-4 fill-current" aria-hidden="true">
                      <path d="M17.5 14.4c-.3-.1-1.7-.8-2-.9-.3-.1-.5-.1-.7.2-.2.3-.7.9-.9 1.1-.2.2-.3.2-.6.1-.3-.1-1.2-.4-2.3-1.4-.9-.8-1.4-1.7-1.6-2-.2-.3 0-.5.1-.6.1-.1.3-.3.4-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5 0-.1-.7-1.6-.9-2.2-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.4 0 1.4 1.1 2.8 1.2 3 .1.2 2.1 3.2 5 4.5.7.3 1.3.5 1.7.6.7.2 1.4.2 1.9.1.6-.1 1.7-.7 2-1.4.2-.7.2-1.2.2-1.4-.1-.1-.3-.2-.7-.4zM12 2C6.5 2 2 6.5 2 12c0 1.8.5 3.5 1.3 5L2 22l5.2-1.4c1.4.8 3.1 1.2 4.8 1.2 5.5 0 10-4.5 10-10S17.5 2 12 2z" />
                    </svg>
                    Buy via WhatsApp
                  </a>
                )}
              </div>
            </article>
          );
        })}
      </div>

      <!-- Empty state (shown by JS when filter has no results) -->
      <div id="empty-state" class="hidden py-20 text-center">
        <p class="text-muted-foreground">No assets in this category yet — check back soon.</p>
        <a href="/marketplace" class="mt-4 inline-block text-sm font-bold text-brand-primary hover:text-accent">
          View all assets →
        </a>
      </div>
    </main>

    <!-- Bottom CTA -->
    <div class="mx-auto max-w-7xl px-6 pb-16">
      <div class="ui-card flex flex-col items-center justify-between gap-4 rounded-[1.5rem] px-6 py-6 sm:flex-row">
        <div>
          <p class="font-semibold text-brand-secondary">Need something custom?</p>
          <p class="mt-1 text-sm text-muted-foreground">
            Custom SEO templates, website audits, or branded toolkits — let's discuss on WhatsApp.
          </p>
        </div>
        <a
          href={WHATSAPP_URL}
          target="_blank"
          rel="noreferrer"
          class="inline-flex shrink-0 items-center gap-2 rounded-xl bg-whatsapp px-5 py-3 text-sm font-bold text-white shadow-lg shadow-whatsapp/25 transition-all hover:brightness-110"
        >
          WhatsApp Karein →
        </a>
      </div>
    </div>

    <SiteFooter />
  </div>
</Layout>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.filter-tab');
  const cards = document.querySelectorAll<HTMLElement>('.product-card');
  const emptyState = document.getElementById('empty-state')!;

  function applyFilter(filter: string) {
    let visible = 0;
    cards.forEach((card) => {
      const category = card.dataset.category ?? '';
      const isFree = card.dataset.free === 'true';
      const show =
        filter === 'All' ||
        (filter === 'Free' && isFree) ||
        category === filter;
      card.classList.toggle('hidden', !show);
      if (show) visible++;
    });
    emptyState.classList.toggle('hidden', visible > 0);
  }

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      tabs.forEach((t) => {
        t.classList.remove('bg-brand-primary', 'text-white');
        t.classList.add('text-muted-foreground', 'hover:bg-brand-primary/5', 'hover:text-brand-primary');
        t.setAttribute('aria-selected', 'false');
      });
      tab.classList.add('bg-brand-primary', 'text-white');
      tab.classList.remove('text-muted-foreground', 'hover:bg-brand-primary/5', 'hover:text-brand-primary');
      tab.setAttribute('aria-selected', 'true');
      applyFilter(tab.dataset.tab ?? 'All');
    });
  });
</script>
